#!/usr/bin/env bash
# collar-eval-model — LLM 모델 카테고리 적합도 평가 (멀티 프로바이더)
#
# 브랜드/버전 무관하게 모델 자체를 4개 차원으로 평가해
# collar 카테고리 라우팅 (simple/standard/complex) 배치를 결정한다.
#
# 사용법:
#   collar-eval-model [--provider <provider>] <model-id>
#   collar-eval-model --compare [--provider <provider>] <model-a> <model-b> [model-c...]
#   collar-eval-model --list
#   collar-eval-model --report
#   collar-eval-model --apply --latest
#
# 프로바이더 (auto-detect or explicit):
#   anthropic  — Claude CLI (claude-*)
#   cerebras   — OpenAI-compat API (llama*, qwen*, gpt-oss*, zai-*)
#   gemini     — Gemini CLI (gemini-*)
#
# 예시:
#   collar-eval-model claude-haiku-4-5-20251001
#   collar-eval-model --provider cerebras llama3.1-8b
#   collar-eval-model --compare claude-sonnet-4-6 llama3.1-8b gemini-2.5-flash
#   collar-eval-model --report

set -euo pipefail

COLLAR_HOME="${COLLAR_HOME:-$HOME/.collar}"
EVAL_DIR="$COLLAR_HOME/eval-results"
JUDGE_MODEL="claude-haiku-4-5-20251001"
TODAY="$(date +%Y-%m-%d)"
mkdir -p "$EVAL_DIR"

die() { echo "❌ $*" >&2; exit 1; }
log() { echo "  $*"; }

# ── Claude 바이너리 탐지 ──────────────────────────────────────────
find_claude() {
  for p in /opt/homebrew/bin/claude /usr/local/bin/claude "$HOME/.local/bin/claude"; do
    [ -x "$p" ] && echo "$p" && return
  done
  find "$HOME/.nvm" "$HOME/.local/share/fnm" -name "claude" -type f 2>/dev/null | head -1 || true
}

find_gemini() {
  # PATH 우선 (nvm/fnm 설치 포함)
  command -v gemini 2>/dev/null && return
  for p in /opt/homebrew/bin/gemini /usr/local/bin/gemini "$HOME/.local/bin/gemini"; do
    [ -x "$p" ] && echo "$p" && return
  done
  # nvm 설치 위치 탐색
  find "$HOME/.nvm" -path "*/bin/gemini" -not -name "*.js" 2>/dev/null | head -1 || true
}

CLAUDE_BIN="$(find_claude)"

# Gemini API 키: ~/.codex/config.toml 또는 환경변수
_gemini_api_key() {
  if [ -n "${GEMINI_API_KEY:-}" ]; then
    echo "$GEMINI_API_KEY"
    return
  fi
  # ~/.codex/config.toml 에서 추출
  local cfg="$HOME/.codex/config.toml"
  if [ -f "$cfg" ]; then
    grep 'GEMINI_API_KEY' "$cfg" | grep -o '"[A-Za-z0-9_-]*"' | tr -d '"' | head -1
  fi
}
GEMINI_API_KEY_VAL="$(_gemini_api_key)"

# Codex (OpenAI ChatGPT Pro) 바이너리
find_codex() {
  command -v codex 2>/dev/null && return
  find "$HOME/.nvm" -path "*/bin/codex" 2>/dev/null | head -1 || true
}
CODEX_BIN="$(find_codex)"

# ── 프로바이더 자동 감지 ─────────────────────────────────────────
detect_provider() {
  local model="$1"
  case "$model" in
    claude-*)                          echo "anthropic" ;;
    gemini-*|gemini_*)                 echo "gemini" ;;
    gpt-*|o1|o3|o4-*|o1-*)           echo "codex" ;;
    llama*|qwen*|gpt-oss*|zai-*)      echo "cerebras" ;;
    *)                                 echo "anthropic" ;;
  esac
}

# ── 프로바이더별 실행 ────────────────────────────────────────────
call_model() {
  local provider="$1" model="$2" prompt="$3"

  case "$provider" in
    anthropic)
      [ -n "$CLAUDE_BIN" ] || die "claude CLI를 찾을 수 없습니다."
      "$CLAUDE_BIN" -p --model "$model" "$prompt" 2>/dev/null
      ;;

    gemini)
      # CLI 대신 Gemini API 직접 호출 (15배 빠름)
      local api_key="${GEMINI_API_KEY_VAL:-}"
      [ -n "$api_key" ] || die "GEMINI_API_KEY를 찾을 수 없습니다. ~/.codex/config.toml 또는 GEMINI_API_KEY 환경변수 확인."
      local _tmp_prompt _tmp_req _tmp_out
      _tmp_prompt=$(mktemp); _tmp_req=$(mktemp); _tmp_out=$(mktemp)
      printf '%s' "$prompt" > "$_tmp_prompt"
      python3 -c "
import json, sys
with open(sys.argv[1]) as f:
    prompt = f.read()
print(json.dumps({'contents': [{'parts': [{'text': prompt}]}], 'generationConfig': {'maxOutputTokens': 2048, 'temperature': 0}}))
" "$_tmp_prompt" > "$_tmp_req" 2>/dev/null
      curl -s -X POST \
        "https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${api_key}" \
        -H "Content-Type: application/json" \
        -d "@$_tmp_req" \
        -o "$_tmp_out" \
        --max-time 60 2>/dev/null
      python3 -c "
import json, sys
try:
    data = json.load(open(sys.argv[1]))
    if 'candidates' in data:
        print(data['candidates'][0]['content']['parts'][0]['text'], end='')
    elif 'error' in data:
        print('ERROR:', data['error'].get('message','unknown'), end='')
    else:
        print('ERROR: unexpected response', end='')
except Exception as e:
    print('ERROR:', e, end='')
" "$_tmp_out"
      rm -f "$_tmp_prompt" "$_tmp_req" "$_tmp_out"
      ;;

    codex)
      # OpenAI ChatGPT Pro — codex exec (stdout만 순수 응답, stderr에 헤더)
      [ -n "$CODEX_BIN" ] || die "codex CLI를 찾을 수 없습니다."
      local _tmp_prompt
      _tmp_prompt=$(mktemp)
      printf '%s' "$prompt" > "$_tmp_prompt"
      "$CODEX_BIN" exec -m "$model" < "$_tmp_prompt" 2>/dev/null || true
      rm -f "$_tmp_prompt"
      ;;

    cerebras)
      local api_key="${CEREBRAS_API_KEY:-}"
      [ -n "$api_key" ] || die "CEREBRAS_API_KEY 환경변수가 설정되지 않았습니다."
      local _tmp_prompt _tmp_req _tmp_out
      _tmp_prompt=$(mktemp); _tmp_req=$(mktemp); _tmp_out=$(mktemp)
      printf '%s' "$prompt" > "$_tmp_prompt"
      python3 -c "
import json, sys
model = sys.argv[1]
with open(sys.argv[2]) as f:
    prompt = f.read()
print(json.dumps({'model': model, 'messages': [{'role': 'user', 'content': prompt}], 'max_tokens': 1024, 'temperature': 0}))
" "$model" "$_tmp_prompt" > "$_tmp_req" 2>/dev/null
      curl -s -X POST "https://api.cerebras.ai/v1/chat/completions" \
        -H "Authorization: Bearer $api_key" \
        -H "Content-Type: application/json" \
        -d "@$_tmp_req" \
        -o "$_tmp_out" \
        --max-time 60 2>/dev/null
      python3 -c "
import json, sys
try:
    data = json.load(open(sys.argv[1]))
    if 'choices' in data:
        print(data['choices'][0]['message']['content'], end='')
    elif 'error' in data:
        print('ERROR:', data['error'].get('message', 'unknown'), end='')
    else:
        print('ERROR: unexpected response', end='')
except Exception as e:
    print('ERROR:', e, end='')
" "$_tmp_out"
      rm -f "$_tmp_prompt" "$_tmp_req" "$_tmp_out"
      ;;

    *)
      die "알 수 없는 프로바이더: $provider (지원: anthropic, gemini, codex, cerebras)"
      ;;
  esac
}

# ── 테스트 태스크 ────────────────────────────────────────────────
# SIMPLE: 오타 수정 — 형식 위반 없이 정확히 고치는지
# 오타: caculate→calculate, totall→total, resualt→result, prise→price (4개)
TASK_SIMPLE='There are exactly 4 spelling mistakes in this Python function. Fix ONLY those typos — do not change logic, structure, or variable names beyond the typos. Output ONLY the corrected function (no explanation, no markdown fences, no extra text):

def caculate_totall(items):
    resualt = 0
    for item in items:
        resualt += item.prise
    return resualt'

# STANDARD: 버그 수정 — 버그 이해 + 올바른 수정 + Fix: 설명
TASK_STANDARD='This JavaScript function has a bug: it returns NaN when input is "", null, or undefined.

Fix the bug correctly. Output ONLY two things:
1. The corrected function
2. One comment line starting exactly with "Fix:" explaining what you changed and why

```javascript
function safeParseInt(input) {
    return parseInt(input);
}
```'

# COMPLEX: 아키텍처 사고 평가 — 형식 자유, WHY 설명과 트레이드오프가 핵심
TASK_COMPLEX='You are a backend engineer designing a Redis caching layer.

Context:
- API: user profile read endpoint
- Load: 50,000 req/min peak
- Data staleness: users update profile ~5 times/day
- Stack: PostgreSQL (source of truth) + Redis

Address these 5 concerns. Use any format. For each, explain your reasoning and trade-offs — not just what to do, but WHY:

A. Cache key design
B. TTL value and why that duration
C. Cache invalidation when user data changes
D. Race conditions on concurrent writes
E. Fallback behavior when Redis is unavailable

Show your thinking. There is no length limit.'

TASK_FORMAT='Output EXACTLY this JSON with correct values. No markdown, no explanation, no other text:
{"capital_of_france": "?", "square_root_of_144": "?", "python_year_created": "?"}'

# ── Usage 로그 기록 ──────────────────────────────────────────────
log_usage() {
  local provider="$1" model="$2" task="$3" ms="$4" status="$5"
  local usage_log="$COLLAR_HOME/usage.log"
  local ts
  ts=$(date '+%Y-%m-%dT%H:%M:%S')
  printf '%s\teval\t%s\t%s\t%s\t%d\t%s\n' \
    "$ts" "$provider" "$model" "$task" "$ms" "$status" >> "$usage_log"
}

# ── 단일 모델 실행 (시간 측정 포함) ─────────────────────────────
run_task() {
  local provider="$1" model="$2" prompt="$3" task_label="${4:-unknown}"
  local t_start t_end ms output status

  t_start=$(python3 -c "import time; print(int(time.time()*1000))")
  output=$(call_model "$provider" "$model" "$prompt" || echo "ERROR: model invocation failed")
  t_end=$(python3 -c "import time; print(int(time.time()*1000))")
  ms=$((t_end - t_start))

  if printf '%s' "$output" | grep -q '^ERROR:'; then
    status="error"
  else
    status="ok"
  fi
  log_usage "$provider" "$model" "$task_label" "$ms" "$status"

  printf '%s\n__MS__%d\n' "$output" "$ms"
}

split_output() { printf '%s' "$1" | grep -v '^__MS__'; }
split_ms()     { printf '%s' "$1" | grep '^__MS__' | cut -c7-; }

# ── Judge: 정확성 채점 (Correctness) ────────────────────────────
# "답이 맞는가" — 형식보다 내용 정확성 기준
judge_correctness() {
  local task_type="$1" response="$2"
  [ -n "$CLAUDE_BIN" ] || { echo '{"score": 5, "reason": "judge unavailable"}'; return; }

  local criteria
  case "$task_type" in
    simple)   criteria="All 4 typos fixed (caculate→calculate, totall→total, resualt→result, prise→price). Logic unchanged." ;;
    standard) criteria="Bug correctly fixed: handles empty string, null, undefined — returns 0 not NaN. Fix: comment present." ;;
    complex)  criteria="All 5 concerns addressed (key, TTL, invalidation, concurrency, fallback). Technically sound choices." ;;
    format)   criteria="Pure JSON only, all 3 keys with factually correct values (Paris, 12, 1991)." ;;
  esac

  "$CLAUDE_BIN" -p --model "$JUDGE_MODEL" \
"Judge the CORRECTNESS of this AI response. Focus on: did it actually solve the problem correctly?
Task: $task_type
Criteria: $criteria

Response (first 1000 chars):
---
${response:0:1000}
---

Output ONLY JSON: {\"score\": <integer 0-10>, \"reason\": \"<max 10 words>\"}" 2>/dev/null \
    || echo '{"score": 5, "reason": "judge unavailable"}'
}

# ── Judge: 사고력 채점 (Reasoning) ─────────────────────────────
# "WHY를 설명하는가, 트레이드오프 고려, 엣지케이스 인식"
judge_reasoning() {
  local task_type="$1" response="$2"
  [ -n "$CLAUDE_BIN" ] || { echo '{"score": 5, "reason": "judge unavailable"}'; return; }

  local criteria
  case "$task_type" in
    simple)
      criteria="Did the model identify ALL 4 typos precisely and apply ONLY minimal correct changes (no over-engineering, no added logic)?"
      ;;
    standard)
      criteria="Does the fix show understanding of WHY parseInt fails (no radix, coerces empty string to NaN)? Is the chosen solution robust (handles all edge cases: '', null, undefined, non-numeric)?"
      ;;
    complex)
      criteria="Evaluate reasoning depth:
(1) Does it explain WHY for each technical decision (not just what)?
(2) Are trade-offs explicitly discussed (e.g., TTL too short = DB load, too long = stale data)?
(3) Are failure modes addressed (Redis down, cache stampede, split-brain)?
(4) Are the technical choices appropriate for 50k req/min scale?
Score 0-10 based on depth of thinking shown."
      ;;
    format)
      criteria="Did the model follow instructions precisely with zero deviation? Penalize any extra text, markdown, or wrong values."
      ;;
  esac

  "$CLAUDE_BIN" -p --model "$JUDGE_MODEL" \
"Judge the REASONING QUALITY of this AI response. Focus on: does it show deep understanding, not just a correct answer?
Task: $task_type
Reasoning criteria: $criteria

Response (first 1200 chars):
---
${response:0:1200}
---

Output ONLY JSON: {\"score\": <integer 0-10>, \"reason\": \"<max 12 words>\"}" 2>/dev/null \
    || echo '{"score": 5, "reason": "judge unavailable"}'
}

_extract_json_field() {
  local raw="$1" field="$2" default="${3:-5}"
  python3 -c "
import json, re
raw='''${raw//\'/\'\\\'\'}'''
m = re.search(r'\{[^{}]+\}', raw, re.DOTALL)
try:
    print(json.loads(m.group()).get('${field}', ${default}) if m else ${default})
except:
    print(${default})
" 2>/dev/null || echo "$default"
}

extract_score()  { _extract_json_field "$1" "score" 5; }
extract_reason() {
  python3 -c "
import json, re
raw='''$1'''
m = re.search(r'\{[^{}]+\}', raw, re.DOTALL)
try:
    print(json.loads(m.group()).get('reason', '') if m else '')
except:
    print('')
" 2>/dev/null || echo ""
}

# ── 속도 점수 (ms → 0-10, 역비례) ───────────────────────────────
# 2000ms=10점 / 8000ms=5점 / 20000ms=0점
speed_score() {
  python3 -c "
ms=int('${1:-10000}')
score=max(0,min(10,round(10-(ms-2000)/1800)))
print(score)" 2>/dev/null || echo 5
}

# ── 3차원 가중 점수 계산 ─────────────────────────────────────────
# simple:   correctness*0.50 + reasoning*0.10 + speed*0.40
# standard: correctness*0.45 + reasoning*0.25 + speed*0.30
# complex:  correctness*0.30 + reasoning*0.55 + speed*0.15
# format:   correctness*1.00 (지시 준수 = correctness)
weighted_score() {
  local category="$1" corr="$2" reas="$3" spd="$4"
  python3 -c "
corr=$corr; reas=$reas; spd=$spd
weights = {
  'simple':   (0.50, 0.10, 0.40),
  'standard': (0.45, 0.25, 0.30),
  'complex':  (0.30, 0.55, 0.15),
  'format':   (1.00, 0.00, 0.00),
}
wc, wr, ws = weights.get('$category', (0.50, 0.20, 0.30))
print(round(corr*wc + reas*wr + spd*ws, 1))
" 2>/dev/null || echo 5
}

# ── 카테고리 추천 로직 ──────────────────────────────────────────
recommend_category() {
  python3 -c "
s_total=$1; t_total=$2; c_total=$3
# 단순 최고점 카테고리 추천 (보너스 없음)
cats = {'simple': s_total, 'standard': t_total, 'complex': c_total}
best = max(cats, key=cats.get)
print(best)
"
}

# ── 단일 모델 평가 (3차원: correctness + reasoning + speed) ──────
eval_single() {
  local provider="$1" model="$2"
  local safe_name="${model//\//_}"
  local result_file="$EVAL_DIR/${safe_name}_${TODAY}.json"

  echo ""
  echo "━━━ collar eval-model: $model [$provider] ━━━"
  echo ""

  log "1/4 SIMPLE 테스트 중..."
  SIMPLE_RAW="$(run_task "$provider" "$model" "$TASK_SIMPLE" "simple")"
  SIMPLE_OUT="$(split_output "$SIMPLE_RAW")"
  SIMPLE_MS="$(split_ms "$SIMPLE_RAW")"

  log "2/4 STANDARD 테스트 중..."
  STD_RAW="$(run_task "$provider" "$model" "$TASK_STANDARD" "standard")"
  STD_OUT="$(split_output "$STD_RAW")"
  STD_MS="$(split_ms "$STD_RAW")"

  log "3/4 COMPLEX 테스트 중..."
  CPX_RAW="$(run_task "$provider" "$model" "$TASK_COMPLEX" "complex")"
  CPX_OUT="$(split_output "$CPX_RAW")"
  CPX_MS="$(split_ms "$CPX_RAW")"

  log "4/4 FORMAT 테스트 중..."
  FMT_RAW="$(run_task "$provider" "$model" "$TASK_FORMAT" "format")"
  FMT_OUT="$(split_output "$FMT_RAW")"
  FMT_MS="$(split_ms "$FMT_RAW")"

  echo ""
  log "🤖 judge ($JUDGE_MODEL) 정확성 채점 중..."
  S_CJ="$(judge_correctness "simple"   "$SIMPLE_OUT")"
  T_CJ="$(judge_correctness "standard" "$STD_OUT")"
  C_CJ="$(judge_correctness "complex"  "$CPX_OUT")"
  F_CJ="$(judge_correctness "format"   "$FMT_OUT")"

  log "🧠 judge ($JUDGE_MODEL) 사고력 채점 중..."
  S_RJ="$(judge_reasoning "simple"   "$SIMPLE_OUT")"
  T_RJ="$(judge_reasoning "standard" "$STD_OUT")"
  C_RJ="$(judge_reasoning "complex"  "$CPX_OUT")"
  F_RJ="$(judge_reasoning "format"   "$FMT_OUT")"

  # 정확성 점수
  S_CORR="$(extract_score "$S_CJ")"; S_CORR_R="$(extract_reason "$S_CJ")"
  T_CORR="$(extract_score "$T_CJ")"; T_CORR_R="$(extract_reason "$T_CJ")"
  C_CORR="$(extract_score "$C_CJ")"; C_CORR_R="$(extract_reason "$C_CJ")"
  F_CORR="$(extract_score "$F_CJ")"; F_CORR_R="$(extract_reason "$F_CJ")"

  # 사고력 점수
  S_REAS="$(extract_score "$S_RJ")"; S_REAS_R="$(extract_reason "$S_RJ")"
  T_REAS="$(extract_score "$T_RJ")"; T_REAS_R="$(extract_reason "$T_RJ")"
  C_REAS="$(extract_score "$C_RJ")"; C_REAS_R="$(extract_reason "$C_RJ")"
  F_REAS="$(extract_score "$F_RJ")"

  # 속도 점수
  S_SPEED="$(speed_score "$SIMPLE_MS")"
  T_SPEED="$(speed_score "$STD_MS")"
  C_SPEED="$(speed_score "$CPX_MS")"

  # 3차원 가중 합산 (simple/standard/complex 각각 다른 가중치)
  S_TOTAL="$(weighted_score "simple"   "$S_CORR" "$S_REAS" "$S_SPEED")"
  T_TOTAL="$(weighted_score "standard" "$T_CORR" "$T_REAS" "$T_SPEED")"
  C_TOTAL="$(weighted_score "complex"  "$C_CORR" "$C_REAS" "$C_SPEED")"

  RECO="$(recommend_category "$S_TOTAL" "$T_TOTAL" "$C_TOTAL")"

  echo ""
  echo "┌──────────────────────────────────────────────────────────────────┐"
  printf "│  모델: %-58s │\n" "$model"
  printf "│  프로바이더: %-54s │\n" "$provider"
  echo "├──────────┬──────────┬──────────┬────────┬─────────────────────────┤"
  echo "│ 카테고리 │ 정확성↑  │ 사고력↑  │  속도  │ 종합  │ 사고 판정             │"
  echo "├──────────┼──────────┼──────────┼────────┼───────┼───────────────────────┤"
  printf "│ %-8s │  %2s/10   │  %2s/10   │%5sms │  %-4s │ %-21s │\n" \
    "SIMPLE"   "$S_CORR" "$S_REAS" "${SIMPLE_MS:-?}" "$S_TOTAL" "${S_REAS_R:0:21}"
  printf "│ %-8s │  %2s/10   │  %2s/10   │%5sms │  %-4s │ %-21s │\n" \
    "STANDARD" "$T_CORR" "$T_REAS" "${STD_MS:-?}"    "$T_TOTAL" "${T_REAS_R:0:21}"
  printf "│ %-8s │  %2s/10   │  %2s/10   │%5sms │  %-4s │ %-21s │\n" \
    "COMPLEX"  "$C_CORR" "$C_REAS" "${CPX_MS:-?}"    "$C_TOTAL" "${C_REAS_R:0:21}"
  printf "│ %-8s │  %2s/10   │ %-8s │%-6s  │  %-4s │ %-21s │\n" \
    "FORMAT"   "$F_CORR" "(형식준수)" ""              "$F_CORR"  "${F_CORR_R:0:21}"
  echo "├──────────┴──────────┴──────────┴────────┴───────┴───────────────────────┤"
  echo "│  가중치: simple(정확50%+사고10%+속도40%)  standard(45%+25%+30%)         │"
  echo "│          complex(정확30%+사고55%+속도15%)                                │"
  echo "├──────────────────────────────────────────────────────────────────┤"
  printf "│  🎯 추천 카테고리: %-46s │\n" "$RECO"
  echo "└──────────────────────────────────────────────────────────────────┘"
  echo ""

  # JSON 저장
  python3 - << PYEOF
import json, pathlib
result = {
    "model": "$model",
    "provider": "$provider",
    "date": "$TODAY",
    "eval_version": "v2-3dim",
    "scores": {
        "simple": {
            "correctness": $S_CORR, "reasoning": $S_REAS,
            "speed_ms": ${SIMPLE_MS:-0}, "speed_score": $S_SPEED,
            "total": $S_TOTAL,
            "correctness_reason": "$S_CORR_R", "reasoning_reason": "$S_REAS_R"
        },
        "standard": {
            "correctness": $T_CORR, "reasoning": $T_REAS,
            "speed_ms": ${STD_MS:-0}, "speed_score": $T_SPEED,
            "total": $T_TOTAL,
            "correctness_reason": "$T_CORR_R", "reasoning_reason": "$T_REAS_R"
        },
        "complex": {
            "correctness": $C_CORR, "reasoning": $C_REAS,
            "speed_ms": ${CPX_MS:-0}, "speed_score": $C_SPEED,
            "total": $C_TOTAL,
            "correctness_reason": "$C_CORR_R", "reasoning_reason": "$C_REAS_R"
        },
        "format": {
            "correctness": $F_CORR, "total": $F_CORR,
            "correctness_reason": "$F_CORR_R"
        }
    },
    "recommendation": "$RECO"
}
pathlib.Path("$result_file").write_text(json.dumps(result, indent=2, ensure_ascii=False))
print("  결과 저장:", "$result_file")
PYEOF
}

# ── 비교 모드 ────────────────────────────────────────────────────
eval_compare() {
  local provider_override="$1"
  shift
  local models=("$@")
  local all_results=()

  for model in "${models[@]}"; do
    local p="${provider_override:-$(detect_provider "$model")}"
    eval_single "$p" "$model"
    local safe="${model//\//_}"
    all_results+=("$EVAL_DIR/${safe}_${TODAY}.json")
  done

  echo ""
  echo "━━━ 비교 요약 ━━━"
  echo ""
  python3 - "${all_results[@]}" << 'PYEOF'
import json, sys, pathlib

files = sys.argv[1:]
results = []
for f in files:
    try:
        results.append(json.loads(pathlib.Path(f).read_text()))
    except: pass

if not results:
    print("결과 없음")
    sys.exit(0)

print(f"{'모델':<35} {'프로바이더':<12} {'SIMPLE':>8} {'STANDARD':>10} {'COMPLEX':>9} {'추천':>10}")
print("-" * 88)
for r in results:
    s = r["scores"]
    prov = r.get("provider", "?")
    print(f"{r['model']:<35} {prov:<12} {s['simple']['total']:>8} {s['standard']['total']:>10} {s['complex']['total']:>9} {r['recommendation']:>10}")

print()
print("카테고리별 최적 모델:")
cats = ["simple", "standard", "complex"]
for cat in cats:
    best = max(results, key=lambda r: r["scores"][cat]["total"])
    prov = best.get("provider", "?")
    print(f"  {cat:10}: {best['model']} [{prov}] ({best['scores'][cat]['total']}/10)")
PYEOF
}

# ── 저장 결과 리포트 ─────────────────────────────────────────────
eval_report() {
  echo ""
  echo "━━━ collar eval-model 결과 리포트 ━━━"
  echo ""

  python3 - "$EVAL_DIR" << 'PYEOF'
import json, pathlib, sys, os

eval_dir = pathlib.Path(sys.argv[1])
files = sorted(eval_dir.glob("*.json"), key=os.path.getmtime, reverse=True)

if not files:
    print("저장된 평가 결과 없음.")
    print("실행: collar-eval-model <model-id>")
    sys.exit(0)

print(f"총 {len(files)}개 평가 결과 (최신순)\n")
print(f"{'날짜':<12} {'프로바이더':<12} {'모델':<35} {'simple':>7} {'standard':>9} {'complex':>8} {'추천':>10}")
print("-" * 97)

for f in files:
    try:
        r = json.loads(f.read_text())
        s = r["scores"]
        prov = r.get("provider", "?")
        print(f"{r['date']:<12} {prov:<12} {r['model']:<35} {s['simple']['total']:>7} {s['standard']['total']:>9} {s['complex']['total']:>8} {r['recommendation']:>10}")
    except:
        pass

results = []
for f in files:
    try: results.append(json.loads(f.read_text()))
    except: pass

if results:
    print()
    print("카테고리별 역대 최적 모델:")
    for cat in ["simple", "standard", "complex"]:
        best = max(results, key=lambda r: r["scores"][cat]["total"])
        prov = best.get("provider", "?")
        print(f"  {cat:10}: {best['model']} [{prov}] ({best['scores'][cat]['total']}/10) — {best['date']}")
PYEOF
}

# ── 평가 결과를 model-routing.json에 반영 ────────────────────────
apply_routing() {
  local result_file="$1"
  local routing_file="$COLLAR_HOME/model-routing.json"

  [ -f "$result_file" ] || die "결과 파일 없음: $result_file"

  python3 - "$result_file" "$routing_file" << 'PYEOF'
import json, pathlib, sys, datetime

result_path = pathlib.Path(sys.argv[1])
routing_path = pathlib.Path(sys.argv[2])

result = json.loads(result_path.read_text())
model = result["model"]
provider = result.get("provider", "anthropic")
scores = result["scores"]
recommendation = result["recommendation"]

if routing_path.exists():
    routing = json.loads(routing_path.read_text())
else:
    routing = {"version": "1.0", "routing": {}, "providers": {}}

cat = recommendation
routing.setdefault("routing", {})[cat] = {
    "provider": provider,
    "model": model,
    "source": "eval",
    "eval_score": scores[cat]["total"],
    "updated": datetime.date.today().isoformat()
}
routing["updated"] = datetime.date.today().isoformat()

routing_path.parent.mkdir(parents=True, exist_ok=True)
routing_path.write_text(json.dumps(routing, indent=2, ensure_ascii=False))
print(f"✅ model-routing.json 업데이트: {cat} → {model} [{provider}] (score: {scores[cat]['total']})")
PYEOF
}

# ── 엔트리포인트 ────────────────────────────────────────────────
PROVIDER_OVERRIDE=""
POSITIONAL=()

# 인수 파싱
while [[ $# -gt 0 ]]; do
  case "$1" in
    --provider)
      PROVIDER_OVERRIDE="$2"
      shift 2
      ;;
    --apply)
      shift
      [ $# -ge 1 ] || die "--apply <result.json> 또는 --apply --latest"
      if [ "$1" = "--latest" ]; then
        latest=$(ls -t "$EVAL_DIR"/*.json 2>/dev/null | head -1)
        [ -n "$latest" ] || die "저장된 평가 결과 없음"
        apply_routing "$latest"
      else
        apply_routing "$1"
      fi
      exit 0
      ;;
    --compare)
      shift
      [ $# -ge 2 ] || die "--compare는 최소 2개 모델 필요"
      eval_compare "$PROVIDER_OVERRIDE" "$@"
      exit 0
      ;;
    --list|--report)
      eval_report
      exit 0
      ;;
    --help|-h)
      cat << 'EOF'
collar-eval-model — LLM 모델 카테고리 적합도 평가 (멀티 프로바이더)

사용법:
  collar-eval-model [--provider <prov>] <model-id>       단일 모델 평가
  collar-eval-model --compare [--provider <prov>] <a> <b> [c...]  비교
  collar-eval-model --report                              저장된 결과 요약
  collar-eval-model --apply --latest                      최근 결과를 routing에 적용

프로바이더 (자동 감지 또는 --provider로 명시):
  anthropic  — Claude CLI         (claude-* / Claude Max 구독)
  gemini     — Gemini API 직접    (gemini-* / Gemini Pro 구독, ~/.codex/config.toml 키 사용)
  codex      — OpenAI Codex CLI   (gpt-*, o3, o4-* / ChatGPT Pro 구독)
  cerebras   — Cerebras API       (llama*, qwen*, gpt-oss* / TEST ONLY — 프로덕션 금지)
               환경변수: CEREBRAS_API_KEY

평가 항목:
  SIMPLE   — 오타/명백한 버그 수정 (품질 60% + 속도 40%)
  STANDARD — 일반 버그 수정 (품질 70% + 속도 30%)
  COMPLEX  — 아키텍처 설계 (품질 85% + 속도 15%)
  FORMAT   — 지시 형식 준수

결과 저장: ~/.collar/eval-results/<model>_<date>.json

예시:
  collar-eval-model claude-haiku-4-5-20251001
  collar-eval-model --provider cerebras llama3.1-8b
  collar-eval-model gemini-2.5-flash
  collar-eval-model --compare claude-sonnet-4-6 llama3.1-8b gemini-2.5-flash
  collar-eval-model --apply --latest
EOF
      exit 0
      ;;
    "")
      cat << 'EOF'
collar-eval-model — 사용법: collar-eval-model --help
EOF
      exit 0
      ;;
    *)
      POSITIONAL+=("$1")
      shift
      ;;
  esac
done

# 나머지 positional 처리
if [ ${#POSITIONAL[@]} -eq 0 ]; then
  cat << 'EOF'
collar-eval-model — LLM 모델 카테고리 적합도 평가

사용법:
  collar-eval-model <model-id>
  collar-eval-model --help

예시:
  collar-eval-model claude-haiku-4-5-20251001
  collar-eval-model --provider cerebras llama3.1-8b
  collar-eval-model gemini-2.5-flash
EOF
  exit 0
fi

MODEL="${POSITIONAL[0]}"
PROVIDER="${PROVIDER_OVERRIDE:-$(detect_provider "$MODEL")}"

# Cerebras 사용 시 API 키 확인
if [ "$PROVIDER" = "cerebras" ] && [ -z "${CEREBRAS_API_KEY:-}" ]; then
  die "Cerebras 모델 평가에는 CEREBRAS_API_KEY 환경변수가 필요합니다.
  설정: export CEREBRAS_API_KEY=<your-key>"
fi

eval_single "$PROVIDER" "$MODEL"
