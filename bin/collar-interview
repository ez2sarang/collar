#!/usr/bin/env bash
# collar-interview — 대화형 인터뷰로 프로젝트 맞춤형 CLAUDE.md 생성
# 사용법: collar-interview [프로젝트-폴더]
#          collar-interview --dry-run

set -euo pipefail

TARGET="${1:-.}"
DRY_RUN=false
[ "${1:-}" = "--dry-run" ] && DRY_RUN=true && TARGET="."
TARGET="$(cd "$TARGET" && pwd)"
PROJECT_NAME="$(basename "$TARGET")"
CLAUDE_FILE="$TARGET/CLAUDE.md"

echo "🎙️  collar-interview: $PROJECT_NAME"

# --dry-run 모드 분기
if [ "$DRY_RUN" = "true" ]; then
  echo "   구조 검증 모드 (--dry-run, 실제 인터뷰 없음)"
  echo ""

  # 기본값으로 진행
  Q_PURPOSE="테스트 프로젝트"
  Q_USERS="테스트 사용자"
  Q_DEPLOY="없음"
  Q_PRIORITY="기능구현"
  Q_FORBIDDEN=""
  Q_DONE="테스트 완료"
  Q_TEST="없음"

  echo "📋 기본값으로 미리보기를 생성합니다..."
  echo ""
else
  echo "   대화형 인터뷰로 프로젝트 맞춤형 CLAUDE.md를 만들게요 (~5분)"
  echo ""

  # ── 질문 함수 ─────────────────────────────────────────────────────
  ask() {
    local question="$1"
    local varname="$2"
    local default="${3:-}"
    echo -n "❓ $question"
    [ -n "$default" ] && echo -n " [기본값: $default]"
    echo ": "
    read -r answer
    [ -z "$answer" ] && answer="$default"
    eval "$varname=\"$answer\""
  }

  # ── 7개 질문 수집 ──────────────────────────────────────────────────
  echo "질문에 답변해주세요 (Enter로 기본값 선택 가능)"
  echo ""

  Q_PURPOSE=""
  Q_USERS=""
  Q_DEPLOY=""
  Q_PRIORITY=""
  Q_FORBIDDEN=""
  Q_DONE=""
  Q_TEST=""

  ask "1️⃣  이 프로젝트는 무엇인가요? (한 줄 설명)" Q_PURPOSE
  ask "2️⃣  주 사용자/고객은?" Q_USERS "나 혼자"
  ask "3️⃣  배포 환경은?" Q_DEPLOY "없음"
  ask "4️⃣  지금 가장 중요한 것은?" Q_PRIORITY "기능구현"
  ask "5️⃣  AI가 절대 하면 안 되는 것? (없으면 Enter)" Q_FORBIDDEN ""
  ask "6️⃣  성공 기준은? (완성됐다고 느끼려면 뭐가 필요한지)" Q_DONE
  ask "7️⃣  빌드/테스트 명령어는?" Q_TEST "없음"
fi

echo ""
echo "✅ 인터뷰 완료. AI로 CLAUDE.md를 생성 중..."
echo ""

# ── 기존 CLAUDE.md 및 템플릿 읽기 ──────────────────────────────────
EXISTING_CONTENT=""
if [ -f "$CLAUDE_FILE" ]; then
  EXISTING_CONTENT="$(cat "$CLAUDE_FILE")"
fi

# templates 찾기
TEMPLATE_BASE=""
if [ -f "/Users/ez2sarang/Documents/dev/ai/collar/templates/CLAUDE.md.base" ]; then
  TEMPLATE_BASE="$(cat /Users/ez2sarang/Documents/dev/ai/collar/templates/CLAUDE.md.base)"
elif [ -d "$(dirname "$TARGET")/../collar/templates" ]; then
  TEMPLATE_BASE="$(cat "$(dirname "$TARGET")/../collar/templates/CLAUDE.md.base" 2>/dev/null || true)"
fi

# ── 프로젝트 컨텍스트 수집 ─────────────────────────────────────────
CONTEXT_FILE="$(mktemp /tmp/collar-context-XXXXX.md)"
trap "rm -f $CONTEXT_FILE" EXIT

{
  echo "# 인터뷰 답변"
  echo ""
  echo "- **프로젝트 목적:** $Q_PURPOSE"
  echo "- **사용자:** $Q_USERS"
  echo "- **배포 환경:** $Q_DEPLOY"
  echo "- **우선순위:** $Q_PRIORITY"
  echo "- **AI 제한:** $Q_FORBIDDEN"
  echo "- **성공 기준:** $Q_DONE"
  echo "- **테스트:** $Q_TEST"
  echo ""

  if [ -n "$EXISTING_CONTENT" ]; then
    echo "## 기존 CLAUDE.md"
    echo '```markdown'
    echo "$EXISTING_CONTENT"
    echo '```'
    echo ""
  fi

  if [ -n "$TEMPLATE_BASE" ]; then
    echo "## collar 기본 템플릿"
    echo '```markdown'
    echo "$TEMPLATE_BASE"
    echo '```'
    echo ""
  fi

  # package.json
  if [ -f "$TARGET/package.json" ]; then
    echo "## package.json"
    echo '```json'
    cat "$TARGET/package.json"
    echo '```'
    echo ""
  fi

  # pyproject.toml
  if [ -f "$TARGET/pyproject.toml" ]; then
    echo "## pyproject.toml"
    echo '```toml'
    cat "$TARGET/pyproject.toml"
    echo '```'
    echo ""
  fi

  # README.md
  if [ -f "$TARGET/README.md" ]; then
    echo "## README.md (처음 50줄)"
    echo '```'
    head -50 "$TARGET/README.md"
    echo '```'
    echo ""
  fi

  # 디렉토리 구조
  echo "## 디렉토리 구조 (2단계)"
  echo '```'
  find "$TARGET" -maxdepth 2 \
    -not -path '*/node_modules/*' \
    -not -path '*/.git/*' \
    -not -path '*/__pycache__/*' \
    -not -path '*/target/*' \
    -not -path '*/.collar/*' \
    -not -name '*.log' \
    -not -name '.DS_Store' \
    | sort | sed "s|$TARGET/||" | head -40
  echo '```'

} > "$CONTEXT_FILE"

# ── AI 프롬프트 구성 ──────────────────────────────────────────────
PROMPT="다음 인터뷰 답변과 프로젝트 컨텍스트를 기반으로 프로젝트 맞춤형 CLAUDE.md를 작성해주세요.

## 인터뷰 답변
- 프로젝트 목적: $Q_PURPOSE
- 사용자: $Q_USERS
- 배포 환경: $Q_DEPLOY
- 우선순위: $Q_PRIORITY
- AI 제한: $Q_FORBIDDEN
- 성공 기준: $Q_DONE
- 테스트: $Q_TEST

## 작성 규칙
1. '# 프로젝트명 — 설명' 형식으로 시작
2. 프로젝트 목적을 명확하게 섹션화
3. 에이전트 규칙 섹션 포함 (역할 분리, 검증 기준)
4. 모델 라우팅 섹션 포함
5. AI 제한 사항이 있으면 명시적으로 작성
6. 완료 기준 섹션 포함
7. 마크다운 코드블록 없이 CLAUDE.md 내용만 출력 (마크다운 형식의 내용만, 설명 텍스트 없음)

## 프로젝트 컨텍스트
$(cat "$CONTEXT_FILE")

중요: 출력은 마크다운 형식의 CLAUDE.md 내용만. 첫 줄부터 '# ' 헤더로 시작하고, 앞에 다른 텍스트가 없어야 합니다."

# ── LLM 선택 및 실행 ──────────────────────────────────────────────
LLM_OUTPUT=""
LLM_USED=""

# claude -p 시도
if command -v claude >/dev/null 2>&1 || [ -x "/opt/homebrew/bin/claude" ]; then
  echo "🤖 Claude로 분석 중..."
  CLAUDE_BIN="${CLAUDE_PATH:-/opt/homebrew/bin/claude}"
  LLM_OUTPUT="$("$CLAUDE_BIN" -p "$PROMPT" 2>/dev/null)" && LLM_USED="claude" || true
fi

# claude 실패 시 gemini 시도
if [ -z "$LLM_OUTPUT" ] && command -v gemini >/dev/null 2>&1; then
  echo "🤖 Gemini로 분석 중 (claude 실패 fallback)..."
  LLM_OUTPUT="$(echo "$PROMPT" | gemini -p --approval-mode yolo 2>/dev/null)" && LLM_USED="gemini" || true
fi

if [ -z "$LLM_OUTPUT" ]; then
  echo "❌ AI 분석 실패. claude 또는 gemini CLI가 필요합니다."
  exit 1
fi

echo "   [$LLM_USED 분석 완료]"
echo ""

# ── 결과 적용 ──────────────────────────────────────────────────────
if [ "$DRY_RUN" = "true" ]; then
  echo "── 미리보기 (--dry-run, 실제 변경 없음) ──────────────────"
  echo "$LLM_OUTPUT" | head -80
  echo "..."
  echo "──────────────────────────────────────────────────────"
  echo ""
  echo "실제 적용하려면: collar-interview (--dry-run 없이)"
  exit 0
fi

# LLM 출력 정제: 첫 번째 '# ' 헤더 앞의 preamble 텍스트 제거
CLEANED_OUTPUT="$(echo "$LLM_OUTPUT" | awk '/^# /{found=1} found{print}')"

# 정제 후에도 #로 시작하지 않으면 LLM 출력 오염으로 판단 → 중단
if [ -z "$CLEANED_OUTPUT" ] || ! echo "$CLEANED_OUTPUT" | head -1 | grep -q "^#"; then
  echo "❌ LLM 출력이 CLAUDE.md 형식이 아닙니다 (preamble 오염 감지)."
  echo "   LLM 출력 첫 줄: $(echo "$LLM_OUTPUT" | head -1)"
  exit 1
fi
LLM_OUTPUT="$CLEANED_OUTPUT"

# 백업 먼저 (기존 파일이 있으면)
if [ -f "$CLAUDE_FILE" ]; then
  BACKUP="$CLAUDE_FILE.backup.$(date +%Y%m%d-%H%M%S)"
  cp "$CLAUDE_FILE" "$BACKUP"
  echo "📦 기존 CLAUDE.md 백업: $BACKUP"
fi

# CLAUDE.md 업데이트
echo "$LLM_OUTPUT" > "$CLAUDE_FILE"
echo "✅ CLAUDE.md 생성 완료"
echo ""

# ── 인터뷰 기록 저장 ──────────────────────────────────────────────
TODAY="$(date +%Y-%m-%d)"
INTERVIEW_FILE="$TARGET/doc/${TODAY}-interview-$(echo "$PROJECT_NAME" | tr '/' '-').md"

mkdir -p "$(dirname "$INTERVIEW_FILE")"

{
  echo "# 인터뷰 기록: $PROJECT_NAME ($TODAY)"
  echo ""
  echo "## 인터뷰 답변"
  echo ""
  echo "### Q1. 프로젝트 목적"
  echo "$Q_PURPOSE"
  echo ""
  echo "### Q2. 사용자/고객"
  echo "$Q_USERS"
  echo ""
  echo "### Q3. 배포 환경"
  echo "$Q_DEPLOY"
  echo ""
  echo "### Q4. 우선순위"
  echo "$Q_PRIORITY"
  echo ""
  echo "### Q5. AI 제한 사항"
  [ -n "$Q_FORBIDDEN" ] && echo "$Q_FORBIDDEN" || echo "(없음)"
  echo ""
  echo "### Q6. 성공 기준"
  echo "$Q_DONE"
  echo ""
  echo "### Q7. 빌드/테스트"
  echo "$Q_TEST"
  echo ""
  echo "---"
  echo ""
  echo "## 생성된 CLAUDE.md"
  echo ""
  echo '```markdown'
  cat "$CLAUDE_FILE"
  echo '```'
  echo ""
  echo "생성: $TODAY | LLM: $LLM_USED"

} > "$INTERVIEW_FILE"

echo "📝 인터뷰 기록: $INTERVIEW_FILE"
echo ""
echo "🎉 collar-interview 완료!"
echo ""
echo "다음:"
echo "  • CLAUDE.md 검토 후 필요시 수정"
echo "  • Claude Code 재시작하면 업데이트된 하네스 적용"
