#!/usr/bin/env bash
# collar-interview — 대화형 인터뷰로 프로젝트 맞춤형 CLAUDE.md 생성
# Ouroboros 패턴: 명확성 점수 기반 추가 질문 + pressure pass
#
# 사용법:
#   collar-interview [프로젝트-폴더]
#   collar-interview --quick      # clarity scoring 없이 빠른 모드
#   collar-interview --standard   # 기본값 (72%, 2라운드)
#   collar-interview --deep       # 고강도 (82%, 4라운드 + pressure pass 필수)
#   collar-interview --dry-run    # 구조 검증만 (실제 질문 없음)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COLLAR_HOME="${COLLAR_HOME:-$(cd "$SCRIPT_DIR/.." && pwd)}"

# ── 인자 파싱 ─────────────────────────────────────────────────────────
TARGET="."
DRY_RUN=false
QUICK=false
PROFILE="standard"  # standard | deep

for arg in "$@"; do
  case "$arg" in
    --dry-run)  DRY_RUN=true ;;
    --quick)    QUICK=true ;;
    --standard) PROFILE="standard" ;;
    --deep)     PROFILE="deep" ;;
    *)          TARGET="$arg" ;;
  esac
done

TARGET="$(cd "$TARGET" && pwd)"
PROJECT_NAME="$(basename "$TARGET")"
CLAUDE_FILE="$TARGET/CLAUDE.md"

# clarity 설정 (Ouroboros 패턴) — 프로파일별 임계값
if [ "$PROFILE" = "deep" ]; then
  CLARITY_THRESHOLD=82   # deep: 고강도, 더 엄격
  MAX_FOLLOWUP_ROUNDS=4
  PRESSURE_PASS=true     # 가정 압박 재질문 필수
else
  CLARITY_THRESHOLD=72   # standard: 기본
  MAX_FOLLOWUP_ROUNDS=2
  PRESSURE_PASS=false    # standard에서는 선택
fi

echo "🎙️  collar-interview: $PROJECT_NAME"

# ── LLM 실행 함수 ─────────────────────────────────────────────────────
CLAUDE_BIN="${CLAUDE_PATH:-/opt/homebrew/bin/claude}"
LLM_USED=""

run_llm() {
  local prompt="$1"
  local output=""
  # </dev/null: LLM 프로세스가 사용자 stdin을 소비하지 않도록 격리
  if command -v claude >/dev/null 2>&1 || [ -x "$CLAUDE_BIN" ]; then
    output="$("$CLAUDE_BIN" -p "$prompt" </dev/null 2>/dev/null)" && LLM_USED="claude" && echo "$output" && return
  fi
  if [ -z "$output" ] && command -v gemini >/dev/null 2>&1; then
    output="$(echo "$prompt" | gemini -p --approval-mode yolo 2>/dev/null)" && LLM_USED="gemini" && echo "$output" && return
  fi
  return 1
}

# ── 질문 함수 ─────────────────────────────────────────────────────────
ask() {
  local question="$1"
  local varname="$2"
  local default="${3:-}"
  echo -n "❓ $question"
  [ -n "$default" ] && echo -n " [기본값: $default]"
  echo ": "
  read -r answer
  [ -z "$answer" ] && answer="$default"
  eval "$varname=\"$answer\""
}

# ── dry-run / quick 초기화 ───────────────────────────────────────────
if [ "$DRY_RUN" = "true" ]; then
  echo "   구조 검증 모드 (--dry-run, 실제 인터뷰 없음)"
  echo ""
  Q_PURPOSE="테스트 프로젝트"
  Q_USERS="테스트 사용자"
  Q_DEPLOY="없음"
  Q_PRIORITY="기능구현"
  Q_FORBIDDEN=""
  Q_DONE="테스트 완료"
  Q_TEST="없음"
  echo "📋 기본값으로 미리보기를 생성합니다..."
  echo ""
elif [ "$QUICK" = "true" ]; then
  echo "   빠른 모드 (--quick, clarity scoring 없음)"
  echo ""
  ask "1️⃣  이 프로젝트는 무엇인가요? (한 줄 설명)" Q_PURPOSE
  ask "2️⃣  주 사용자/고객은?" Q_USERS "나 혼자"
  ask "3️⃣  배포 환경은?" Q_DEPLOY "없음"
  ask "4️⃣  지금 가장 중요한 것은?" Q_PRIORITY "기능구현"
  ask "5️⃣  AI가 절대 하면 안 되는 것? (없으면 Enter)" Q_FORBIDDEN ""
  ask "6️⃣  성공 기준은?" Q_DONE
  ask "7️⃣  빌드/테스트 명령어는?" Q_TEST "없음"
else
  if [ "$PROFILE" = "deep" ]; then
    echo "   🔬 Deep 모드: 임계값 ${CLARITY_THRESHOLD}%, 최대 ${MAX_FOLLOWUP_ROUNDS}라운드 + pressure pass 필수"
  else
    echo "   📊 Standard 모드: 임계값 ${CLARITY_THRESHOLD}%, 최대 ${MAX_FOLLOWUP_ROUNDS}라운드"
  fi
  echo "   빠른 모드: collar-interview --quick"
  echo ""

  # ── Phase 1: 초기 7문 수집 ─────────────────────────────────────────
  echo "━━━ Phase 1 / 초기 인터뷰 (7문) ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  ask "1️⃣  이 프로젝트는 무엇인가요? (한 줄 설명)" Q_PURPOSE
  ask "2️⃣  주 사용자/고객은?" Q_USERS "나 혼자"
  ask "3️⃣  배포 환경은?" Q_DEPLOY "없음"
  ask "4️⃣  지금 가장 중요한 것은?" Q_PRIORITY "기능구현"
  ask "5️⃣  AI가 절대 하면 안 되는 것? (없으면 Enter)" Q_FORBIDDEN ""
  ask "6️⃣  성공 기준은? (완성됐다고 느끼려면 뭐가 필요한지)" Q_DONE
  ask "7️⃣  빌드/테스트 명령어는?" Q_TEST "없음"
  echo ""

  # ── Phase 2: Clarity Scoring ────────────────────────────────────────
  echo "📊 명확성 분석 중..."
  echo ""

  # 추가 답변 저장소 (follow-up)
  EXTRA_QA=""

  # 현재 답변 요약 함수
  current_answers() {
    cat <<ANSWERS
- 프로젝트 목적: $Q_PURPOSE
- 사용자: $Q_USERS
- 배포 환경: $Q_DEPLOY
- 우선순위: $Q_PRIORITY
- AI 제한: ${Q_FORBIDDEN:-(없음)}
- 성공 기준: $Q_DONE
- 테스트: $Q_TEST
${EXTRA_QA}
ANSWERS
  }

  # 점수 계산 함수 (LLM에게 dimension:score 형식으로 요청)
  score_clarity() {
    local answers="$1"
    local SCORE_PROMPT
    SCORE_PROMPT="다음 프로젝트 인터뷰 답변의 명확성을 평가해주세요.

## 답변
${answers}

## 평가 기준
각 항목을 0-10으로 점수화. 점수 기준:
- 10: 완전히 명확, AI가 즉시 작업 가능
- 7-9: 충분히 명확
- 4-6: 모호함, 가정이 필요
- 1-3: 너무 모호, 핵심 정보 없음

## 출력 형식 (다른 텍스트 없이 이것만)
goal:숫자
users:숫자
deploy:숫자
priority:숫자
constraints:숫자
success:숫자
test:숫자"

    run_llm "$SCORE_PROMPT" 2>/dev/null || echo "goal:5
users:5
deploy:5
priority:5
constraints:5
success:5
test:5"
  }

  # 점수 파싱 및 가중 평균 계산
  parse_and_calc() {
    local raw="$1"
    python3 - << PYEOF
import re, sys

raw = """$raw"""

dims = {
    'goal':        0.28,
    'users':       0.14,
    'deploy':      0.10,
    'priority':    0.14,
    'constraints': 0.14,
    'success':     0.15,
    'test':        0.05,
}
labels = {
    'goal':        '목적/목표',
    'users':       '사용자/고객',
    'deploy':      '배포 환경',
    'priority':    '우선순위',
    'constraints': 'AI 제한',
    'success':     '성공 기준',
    'test':        '테스트',
}

scores = {}
for line in raw.strip().split('\n'):
    m = re.match(r'(\w+):(\d+(?:\.\d+)?)', line.strip())
    if m:
        k, v = m.group(1), float(m.group(2))
        if k in dims:
            scores[k] = min(10, max(0, v))

for k in dims:
    if k not in scores:
        scores[k] = 5.0

weighted = sum(scores[k] * dims[k] for k in dims)
pct = int(weighted * 10)

# 테이블 출력
print("┌─────────────────────────────────────────────┐")
print("│           명확성 점수 (Ouroboros)            │")
print("├──────────────┬───────┬───────────────────────┤")
print("│ 차원         │ 점수  │ 게이지                │")
for k, w in sorted(dims.items(), key=lambda x: -scores.get(x[0], 0)):
    s = scores.get(k, 5.0)
    bar = "█" * int(s) + "░" * (10 - int(s))
    status = "✓" if s >= 7 else ("△" if s >= 5 else "✗")
    print(f"│ {labels[k]:<12} │  {s:4.1f} │ {bar} {status}  │")
print("├──────────────┴───────┴───────────────────────┤")
print(f"│ 종합 명확성: {pct:3d}%  {'✅ 충분' if pct >= ${CLARITY_THRESHOLD} else '⚠️  보완 필요'}                  │")
print("└─────────────────────────────────────────────┘")

# 약한 차원 찾기 (점수 < 7, 가중치 순 정렬)
weak = sorted(
    [(k, scores[k]) for k in dims if scores[k] < 7.0],
    key=lambda x: (x[1], -dims[x[0]])
)

print(f"SCORE_PCT:{pct}")
for k, s in weak[:3]:
    print(f"WEAK:{k}:{s:.1f}")
PYEOF
  }

  # 약한 차원에 대한 follow-up 질문 생성
  followup_question() {
    local dim="$1"
    local score="$2"
    local answers="$3"
    local FQ_PROMPT
    FQ_PROMPT="다음 프로젝트 인터뷰 답변에서 '${dim}' 차원이 ${score}/10으로 낮습니다.

## 현재 답변
${answers}

## 요청
'${dim}' 차원의 명확성을 높일 수 있는 구체적인 후속 질문 1개만 만들어주세요.
질문만 출력하세요. (번호나 이모지 없이, 한국어로)"

    run_llm "$FQ_PROMPT" 2>/dev/null || echo "더 구체적으로 설명해주시겠어요?"
  }

  # ── Phase 2 실행 ────────────────────────────────────────────────────
  ROUND=0
  CURRENT_PCT=0

  while true; do
    RAW_SCORES="$(score_clarity "$(current_answers)")"
    ANALYSIS="$(parse_and_calc "$RAW_SCORES")"

    # 테이블 출력 (SCORE_PCT:/WEAK: 라인 제외)
    echo "$ANALYSIS" | grep -v "^SCORE_PCT:" | grep -v "^WEAK:"
    echo ""

    CURRENT_PCT="$(echo "$ANALYSIS" | grep "^SCORE_PCT:" | head -1 | cut -d: -f2)"
    CURRENT_PCT="${CURRENT_PCT:-50}"

    # 임계값 도달 or 최대 라운드
    if [ "$CURRENT_PCT" -ge "$CLARITY_THRESHOLD" ]; then
      echo "✅ 명확성 ${CURRENT_PCT}% — 임계값 ${CLARITY_THRESHOLD}% 달성. CLAUDE.md 생성을 시작합니다."
      echo ""
      break
    fi

    ROUND=$((ROUND + 1))
    if [ "$ROUND" -gt "$MAX_FOLLOWUP_ROUNDS" ]; then
      echo "⚠️  명확성 ${CURRENT_PCT}% (목표 ${CLARITY_THRESHOLD}%). 최대 라운드 도달."
      echo -n "   그래도 계속 진행할까요? [y/N]: "
      read -r yn
      [ "${yn:-N}" = "y" ] || [ "${yn:-N}" = "Y" ] || { echo "인터뷰를 취소합니다."; exit 0; }
      echo ""
      break
    fi

    # 약한 차원 추출
    WEAK_DIMS="$(echo "$ANALYSIS" | grep "^WEAK:" | head -2)"
    if [ -z "$WEAK_DIMS" ]; then
      break
    fi

    echo "━━━ Phase 2 Round ${ROUND} / 추가 질문 ━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    while IFS= read -r weak_line; do
      [ -z "$weak_line" ] && continue
      DIM="$(echo "$weak_line" | cut -d: -f2)"
      DSCORE="$(echo "$weak_line" | cut -d: -f3)"
      DIM_LABEL_MAP="goal=목적/목표,users=사용자,deploy=배포,priority=우선순위,constraints=AI제한,success=성공기준,test=테스트"
      DIM_LABEL="$(echo "$DIM_LABEL_MAP" | tr ',' '\n' | grep "^${DIM}=" | cut -d= -f2)"

      echo "📍 [${DIM_LABEL:-$DIM}] 현재 ${DSCORE}/10 — 추가 질문 생성 중..."
      FQ="$(followup_question "$DIM_LABEL" "$DSCORE" "$(current_answers)")"
      ask "🔍 $FQ" FQ_ANSWER ""
      if [ -n "$FQ_ANSWER" ]; then
        EXTRA_QA="${EXTRA_QA}
- [추가: ${DIM_LABEL:-$DIM}] ${FQ_ANSWER}"
      fi
      echo ""
    done <<< "$WEAK_DIMS"
  done
  # ── Phase 3: Pressure Pass ─────────────────────────────────────────
  # deep 모드: 필수 / standard 모드: 선택 제안
  RUN_PRESSURE=false
  if [ "$PRESSURE_PASS" = "true" ]; then
    RUN_PRESSURE=true
  else
    echo -n "🔬 가정 압박 재질문을 진행할까요? (더 탄탄한 CLAUDE.md) [y/N]: "
    read -r pp_yn
    [ "${pp_yn:-N}" = "y" ] || [ "${pp_yn:-N}" = "Y" ] && RUN_PRESSURE=true
    echo ""
  fi

  if [ "$RUN_PRESSURE" = "true" ]; then
    echo "━━━ Phase 3 / Pressure Pass ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   앞서 답변한 가정 중 가장 취약한 것에 압박 질문을 드립니다."
    echo ""

    PP_PROMPT="다음 프로젝트 인터뷰 답변을 검토해주세요.

## 답변
$(current_answers)

## 요청
답변 중 가장 취약하거나 검증되지 않은 가정 1개를 골라서,
'만약 그 가정이 틀렸다면?' 식의 압박 질문을 1개만 만들어주세요.

형식: 가정 먼저 1줄로 명시, 그 다음 줄에 질문.
예시:
가정: 사용자가 기술에 익숙할 것이다.
질문: 만약 주 사용자가 비개발자라면, 현재 설계에서 가장 먼저 바꿔야 할 것은 무엇인가요?

질문만 출력 (한국어, 번호/이모지 없이)"

    echo "🤔 가장 취약한 가정 분석 중..."
    PP_OUTPUT="$(run_llm "$PP_PROMPT" 2>/dev/null || echo "가장 중요하다고 하신 목표가 6개월 후에도 유효할까요? 우선순위가 바뀔 수 있는 상황이 있다면 어떤 건가요?")"

    # 가정 줄과 질문 줄 분리
    PP_ASSUMPTION="$(echo "$PP_OUTPUT" | grep -i "^가정:" | head -1 | sed 's/^가정: *//')"
    PP_QUESTION="$(echo "$PP_OUTPUT" | grep -i "^질문:" | head -1 | sed 's/^질문: *//')"
    # fallback: 가정/질문 파싱 실패 시 전체 출력을 질문으로
    [ -z "$PP_QUESTION" ] && PP_QUESTION="$PP_OUTPUT"

    [ -n "$PP_ASSUMPTION" ] && echo "💭 검증 대상 가정: $PP_ASSUMPTION"
    ask "⚡ $PP_QUESTION" PP_ANSWER ""

    if [ -n "$PP_ANSWER" ]; then
      EXTRA_QA="${EXTRA_QA}
- [압박 재질문] ${PP_QUESTION}
- [답변] ${PP_ANSWER}"
    fi
    echo ""
    echo "✅ Pressure Pass 완료."
    echo ""
  fi

fi  # end of Ouroboros mode

echo ""
echo "✅ 인터뷰 완료. AI로 CLAUDE.md를 생성 중..."
echo ""

# ── 프로젝트 컨텍스트 수집 ──────────────────────────────────────────
CONTEXT_FILE="$(mktemp /tmp/collar-context-XXXXX.md)"
trap "rm -f $CONTEXT_FILE" EXIT

EXTRA_BLOCK=""
[ -n "${EXTRA_QA:-}" ] && EXTRA_BLOCK="
## 추가 인터뷰 답변
${EXTRA_QA}"

TEMPLATE_BASE=""
if [ -f "$COLLAR_HOME/templates/CLAUDE.md.base" ]; then
  TEMPLATE_BASE="$(cat "$COLLAR_HOME/templates/CLAUDE.md.base")"
fi

{
  echo "# 인터뷰 답변"
  echo ""
  echo "- **프로젝트 목적:** $Q_PURPOSE"
  echo "- **사용자:** $Q_USERS"
  echo "- **배포 환경:** $Q_DEPLOY"
  echo "- **우선순위:** $Q_PRIORITY"
  echo "- **AI 제한:** ${Q_FORBIDDEN:-(없음)}"
  echo "- **성공 기준:** $Q_DONE"
  echo "- **테스트:** $Q_TEST"
  [ -n "${EXTRA_QA:-}" ] && echo "$EXTRA_QA"
  echo ""

  if [ -n "$TEMPLATE_BASE" ]; then
    echo "## collar 기본 템플릿"
    echo '```markdown'
    echo "$TEMPLATE_BASE"
    echo '```'
    echo ""
  fi

  if [ -f "$TARGET/package.json" ]; then
    echo "## package.json"
    echo '```json'
    cat "$TARGET/package.json"
    echo '```'
    echo ""
  fi

  if [ -f "$TARGET/pyproject.toml" ]; then
    echo "## pyproject.toml"
    echo '```toml'
    cat "$TARGET/pyproject.toml"
    echo '```'
    echo ""
  fi

  if [ -f "$TARGET/README.md" ]; then
    echo "## README.md (처음 50줄)"
    echo '```'
    head -50 "$TARGET/README.md"
    echo '```'
    echo ""
  fi

  echo "## 디렉토리 구조 (2단계)"
  echo '```'
  find "$TARGET" -maxdepth 2 \
    -not -path '*/node_modules/*' \
    -not -path '*/.git/*' \
    -not -path '*/__pycache__/*' \
    -not -path '*/target/*' \
    -not -path '*/.collar/*' \
    -not -name '*.log' \
    -not -name '.DS_Store' \
    | sort | sed "s|$TARGET/||" | head -40
  echo '```'

} > "$CONTEXT_FILE"

# ── CLAUDE.md 생성 ──────────────────────────────────────────────────
PROMPT="다음 인터뷰 답변과 프로젝트 컨텍스트를 기반으로 프로젝트 맞춤형 CLAUDE.md를 작성해주세요.

## 인터뷰 답변
- 프로젝트 목적: $Q_PURPOSE
- 사용자: $Q_USERS
- 배포 환경: $Q_DEPLOY
- 우선순위: $Q_PRIORITY
- AI 제한: ${Q_FORBIDDEN:-(없음)}
- 성공 기준: $Q_DONE
- 테스트: $Q_TEST${EXTRA_BLOCK}

## 작성 규칙
1. '# 프로젝트명 — 설명' 형식으로 시작
2. 프로젝트 목적을 명확하게 섹션화
3. 에이전트 규칙 섹션 포함 (역할 분리, 검증 기준)
4. 모델 라우팅 섹션 포함
5. AI 제한 사항이 있으면 명시적으로 작성
6. 완료 기준 섹션 포함
7. 마크다운 코드블록 없이 CLAUDE.md 내용만 출력

## 프로젝트 컨텍스트
$(cat "$CONTEXT_FILE")

중요: 출력은 마크다운 형식의 CLAUDE.md 내용만. 첫 줄부터 '# ' 헤더로 시작하고, 앞에 다른 텍스트가 없어야 합니다."

echo "🤖 AI로 CLAUDE.md 생성 중..."
LLM_OUTPUT="$(run_llm "$PROMPT")"

if [ -z "$LLM_OUTPUT" ]; then
  echo "❌ AI 분석 실패. claude 또는 gemini CLI가 필요합니다."
  exit 1
fi

echo "   [$LLM_USED 분석 완료]"
echo ""

# ── dry-run 분기 ────────────────────────────────────────────────────
if [ "$DRY_RUN" = "true" ]; then
  echo "── 미리보기 (--dry-run, 실제 변경 없음) ──────────────────────"
  echo "$LLM_OUTPUT" | head -80
  echo "..."
  echo "──────────────────────────────────────────────────────────────"
  echo ""
  echo "실제 적용하려면: collar-interview (--dry-run 없이)"
  exit 0
fi

# ── LLM 출력 정제 ──────────────────────────────────────────────────
CLEANED_OUTPUT="$(echo "$LLM_OUTPUT" | awk '/^# /{found=1} found{print}')"

if [ -z "$CLEANED_OUTPUT" ] || ! echo "$CLEANED_OUTPUT" | head -1 | grep -q "^#"; then
  echo "❌ LLM 출력이 CLAUDE.md 형식이 아닙니다 (preamble 오염 감지)."
  echo "   LLM 출력 첫 줄: $(echo "$LLM_OUTPUT" | head -1)"
  exit 1
fi
LLM_OUTPUT="$CLEANED_OUTPUT"

# ── 백업 및 저장 ────────────────────────────────────────────────────
if [ -f "$CLAUDE_FILE" ]; then
  BACKUP="$CLAUDE_FILE.backup.$(date +%Y%m%d-%H%M%S)"
  cp "$CLAUDE_FILE" "$BACKUP"
  echo "📦 기존 CLAUDE.md 백업: $BACKUP"
fi

echo "$LLM_OUTPUT" > "$CLAUDE_FILE"
echo "✅ CLAUDE.md 생성 완료"
echo ""

# ── 인터뷰 기록 저장 ────────────────────────────────────────────────
TODAY="$(date +%Y-%m-%d)"
INTERVIEW_FILE="$TARGET/doc/${TODAY}-interview-$(echo "$PROJECT_NAME" | tr '/' '-').md"

mkdir -p "$(dirname "$INTERVIEW_FILE")"

{
  echo "# 인터뷰 기록: $PROJECT_NAME ($TODAY)"
  echo ""
  echo "## 인터뷰 답변"
  echo ""
  echo "### Q1. 프로젝트 목적"
  echo "$Q_PURPOSE"
  echo ""
  echo "### Q2. 사용자/고객"
  echo "$Q_USERS"
  echo ""
  echo "### Q3. 배포 환경"
  echo "$Q_DEPLOY"
  echo ""
  echo "### Q4. 우선순위"
  echo "$Q_PRIORITY"
  echo ""
  echo "### Q5. AI 제한 사항"
  [ -n "${Q_FORBIDDEN:-}" ] && echo "$Q_FORBIDDEN" || echo "(없음)"
  echo ""
  echo "### Q6. 성공 기준"
  echo "$Q_DONE"
  echo ""
  echo "### Q7. 빌드/테스트"
  echo "$Q_TEST"
  echo ""
  if [ -n "${EXTRA_QA:-}" ]; then
    echo "### 추가 답변 (clarity follow-up + pressure pass)"
    echo "$EXTRA_QA"
    echo ""
  fi
  if [ -n "${CURRENT_PCT:-}" ]; then
    echo "### 명확성 최종 점수"
    echo "프로파일: ${PROFILE:-standard} | ${CURRENT_PCT}% (임계값: ${CLARITY_THRESHOLD}%)"
    echo ""
  fi
  echo "---"
  echo ""
  echo "## 생성된 CLAUDE.md"
  echo ""
  echo '```markdown'
  cat "$CLAUDE_FILE"
  echo '```'
  echo ""
  echo "생성: $TODAY | LLM: ${LLM_USED:-unknown}"

} > "$INTERVIEW_FILE"

echo "📝 인터뷰 기록: $INTERVIEW_FILE"
echo ""
echo "🎉 collar-interview 완료!"
echo ""
echo "다음:"
echo "  • CLAUDE.md 검토 후 필요시 수정"
echo "  • Claude Code 재시작하면 업데이트된 하네스 적용"
