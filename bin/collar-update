#!/usr/bin/env bash
# collar-update — 코드베이스를 읽어서 CLAUDE.md의 TODO 항목을 AI로 자동 채운다
# 사용법: collar-update [프로젝트-폴더]
#          collar-update --dry-run  (변경 미리보기만)

set -euo pipefail

TARGET="${1:-.}"
DRY_RUN=false
[ "${1:-}" = "--dry-run" ] && DRY_RUN=true && TARGET="."
TARGET="$(cd "$TARGET" && pwd)"
PROJECT_NAME="$(basename "$TARGET")"
CLAUDE_FILE="$TARGET/CLAUDE.md"

echo "🔄 collar-update: $PROJECT_NAME"
echo "   대상: $TARGET"
echo ""

# CLAUDE.md 없으면 안내
if [ ! -f "$CLAUDE_FILE" ]; then
  echo "❌ CLAUDE.md가 없습니다. 먼저 collar-init을 실행하세요."
  exit 1
fi

# TODO가 있는지 확인
TODO_COUNT=$(grep -c "TODO" "$CLAUDE_FILE" 2>/dev/null || true)
if [ "$TODO_COUNT" -eq 0 ]; then
  echo "✅ CLAUDE.md에 TODO 항목이 없습니다. 이미 완성된 상태."
  exit 0
fi

echo "📋 TODO 항목 ${TODO_COUNT}개 발견. AI로 채웁니다."
echo ""

# ── 프로젝트 컨텍스트 수집 ─────────────────────────────────────────
CONTEXT_FILE="$(mktemp /tmp/collar-context-XXXXX.md)"
trap "rm -f $CONTEXT_FILE" EXIT

{
  echo "# 프로젝트 분석 대상: $PROJECT_NAME"
  echo ""

  # package.json
  if [ -f "$TARGET/package.json" ]; then
    echo "## package.json"
    echo '```json'
    cat "$TARGET/package.json"
    echo '```'
    echo ""
  fi

  # pyproject.toml
  if [ -f "$TARGET/pyproject.toml" ]; then
    echo "## pyproject.toml"
    echo '```toml'
    cat "$TARGET/pyproject.toml"
    echo '```'
    echo ""
  fi

  # README.md
  if [ -f "$TARGET/README.md" ]; then
    echo "## README.md (요약용)"
    head -50 "$TARGET/README.md"
    echo ""
  fi

  # 디렉토리 구조
  echo "## 디렉토리 구조 (2단계)"
  echo '```'
  find "$TARGET" -maxdepth 2 \
    -not -path '*/node_modules/*' \
    -not -path '*/.git/*' \
    -not -path '*/__pycache__/*' \
    -not -path '*/target/*' \
    -not -path '*/.collar/*' \
    -not -name '*.log' \
    -not -name '.DS_Store' \
    | sort | sed "s|$TARGET/||" | head -40
  echo '```'
  echo ""

  # 현재 CLAUDE.md
  echo "## 현재 CLAUDE.md (TODO 항목 포함)"
  echo '```markdown'
  cat "$CLAUDE_FILE"
  echo '```'

} > "$CONTEXT_FILE"

# ── AI 프롬프트 구성 ──────────────────────────────────────────────
PROMPT="다음은 프로젝트 분석 정보입니다. CLAUDE.md에서 'TODO:' 로 시작하는 모든 항목을 실제 프로젝트 내용으로 교체해서 CLAUDE.md 전체를 출력해주세요.

규칙:
1. TODO 항목만 실제 내용으로 교체. 나머지는 그대로 유지.
2. {{PROJECT_DESCRIPTION}}: 한 줄 설명 (영어/한국어 모두 OK)
3. {{REPO_STRUCTURE}} 또는 레포 구조: 실제 파일 트리로 교체
4. 검증 명령어가 TODO면 package.json scripts 또는 언어 관례에 맞게 채움
5. 마크다운 코드블록 없이 CLAUDE.md 내용만 출력

$(cat "$CONTEXT_FILE")"

# ── LLM 선택 및 실행 ──────────────────────────────────────────────
LLM_OUTPUT=""
LLM_USED=""

# claude -p 시도
if command -v claude >/dev/null 2>&1 || [ -x "/opt/homebrew/bin/claude" ]; then
  echo "🤖 Claude로 분석 중..."
  CLAUDE_BIN="${CLAUDE_PATH:-/opt/homebrew/bin/claude}"
  LLM_OUTPUT="$("$CLAUDE_BIN" -p "$PROMPT" 2>/dev/null)" && LLM_USED="claude" || true
fi

# claude 실패 시 gemini 시도
if [ -z "$LLM_OUTPUT" ] && command -v gemini >/dev/null 2>&1; then
  echo "🤖 Gemini로 분석 중 (claude 실패 fallback)..."
  LLM_OUTPUT="$(echo "$PROMPT" | gemini -p --approval-mode yolo 2>/dev/null)" && LLM_USED="gemini" || true
fi

if [ -z "$LLM_OUTPUT" ]; then
  echo "❌ AI 분석 실패. claude 또는 gemini CLI가 필요합니다."
  echo "   수동으로 CLAUDE.md의 TODO 항목을 채워주세요."
  exit 1
fi

echo "   [$LLM_USED 분석 완료]"
echo ""

# ── 결과 적용 ──────────────────────────────────────────────────────
if [ "$DRY_RUN" = "true" ]; then
  echo "── 미리보기 (--dry-run, 실제 변경 없음) ──────────────────"
  echo "$LLM_OUTPUT" | head -60
  echo "..."
  echo "──────────────────────────────────────────────────────"
  echo ""
  echo "실제 적용하려면: collar-update (--dry-run 없이)"
  exit 0
fi

# 백업 먼저
BACKUP="$CLAUDE_FILE.backup.$(date +%Y%m%d-%H%M%S)"
cp "$CLAUDE_FILE" "$BACKUP"
echo "📦 백업: $BACKUP"

# CLAUDE.md 업데이트
echo "$LLM_OUTPUT" > "$CLAUDE_FILE"
echo "✅ CLAUDE.md 업데이트 완료"
echo ""

# TODO 항목이 남아있는지 확인
REMAINING=$(grep -c "TODO" "$CLAUDE_FILE" 2>/dev/null || true)
if [ "$REMAINING" -gt 0 ]; then
  echo "⚠️  TODO 항목 ${REMAINING}개가 아직 남아있습니다 (AI가 채우지 못한 항목):"
  grep -n "TODO" "$CLAUDE_FILE" | head -5
  echo ""
fi

# memory.md에 업데이트 기록
if [ -f "$TARGET/.collar/memory.md" ]; then
  TODAY="$(date +%Y-%m-%d)"
  python3 - "$TARGET/.collar/memory.md" "$TODAY" "$LLM_USED" << 'PYEOF'
import sys, pathlib, re, datetime

memory_path, today, llm_used = sys.argv[1], sys.argv[2], sys.argv[3]
content = pathlib.Path(memory_path).read_text()

entry = f"\n### [{today}] collar-update 실행\n**발견:** {llm_used}로 CLAUDE.md TODO 자동 채움\n**적용:** 이후 collar-update 재실행 시 TODO가 없으면 즉시 완료\n"

insert_after = "## 작업 이력 요약"
if insert_after in content:
    pos = content.index(insert_after) + len(insert_after)
    new_content = content[:pos] + "\n" + entry + content[pos:]
else:
    new_content = content + "\n" + entry

new_content = re.sub(r'마지막 업데이트: \d{4}-\d{2}-\d{2}', f'마지막 업데이트: {today}', new_content)
pathlib.Path(memory_path).write_text(new_content)
PYEOF
fi

echo ""
echo "🎉 collar-update 완료!"
echo ""
echo "다음:"
echo "  • CLAUDE.md 검토 후 내용 수정"
echo "  • Claude Code 재시작하면 업데이트된 하네스 적용"
