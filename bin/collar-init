#!/usr/bin/env bash
# collar-init — 프로젝트에 하네스를 설치한다
# 사용법: collar-init [프로젝트-폴더]

set -euo pipefail

# 스크립트 위치 기준으로 COLLAR_HOME 자동 결정 (dev 레포 / ~/.collar 설치 모두 동작)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COLLAR_HOME="${COLLAR_HOME:-$(cd "$SCRIPT_DIR/.." && pwd)}"
TARGET="${1:-.}"
TARGET="$(cd "$TARGET" && pwd)"
PROJECT_NAME="$(basename "$TARGET")"
# DB 스키마명: 프로젝트명을 snake_case로 변환 (camelCase → snake, hyphen → underscore)
DB_SCHEMA="$(echo "$PROJECT_NAME" \
  | sed 's/\([A-Z]\)/_\1/g' \
  | sed 's/-/_/g' \
  | tr '[:upper:]' '[:lower:]' \
  | sed 's/^_//')"

echo "🎯 collar-init: $PROJECT_NAME"
echo "   대상: $TARGET"
echo ""

# ── 언어 선택 ─────────────────────────────────────────────────────
echo "🌐 작업 안내 언어를 선택하세요:"
echo "   1) 한국어 (Korean)  [기본값]"
echo "   2) English"
echo "   3) 日本語 (Japanese)"
echo "   4) 中文 (Chinese)"
read -r -p "선택 [1-4, Enter=한국어]: " _LANG_SEL
case "${_LANG_SEL:-1}" in
  2) COLLAR_LANG="en" ; LANG_LABEL="English" ;;
  3) COLLAR_LANG="ja" ; LANG_LABEL="日本語" ;;
  4) COLLAR_LANG="zh" ; LANG_LABEL="中文" ;;
  *) COLLAR_LANG="ko" ; LANG_LABEL="한국어" ;;
esac
echo "   → $LANG_LABEL 선택됨"
echo ""

# ── 프로젝트 목표 입력 ───────────────────────────────────────────
echo "🎯 프로젝트 목표를 한 줄로 입력하세요."
echo "   (AI가 매 세션 시작 시 이것을 읽어 방향을 유지합니다)"
echo "   예: 소규모 팀용 할일 관리 SaaS — 모바일 우선, 오프라인 지원"
read -r -p "> " PROJECT_GOAL
PROJECT_GOAL="${PROJECT_GOAL:-TODO: 이 프로젝트의 목표를 기록하세요.}"
echo ""

# ── AI 프로바이더 설정 ───────────────────────────────────────────
echo "🤖 사용 중인 AI 구독을 선택하세요 (해당되는 것 모두, 쉼표로 구분):"
echo "   1) Claude Max     (Anthropic CLI — claude 명령어)"
echo "   2) Gemini Pro     (Google Gemini API 직접 호출)"
echo "   3) ChatGPT Pro    (OpenAI Codex CLI — codex 명령어)"
echo "   4) Cerebras       (TEST ONLY — 프로덕션 사용 금지)"
echo "   예: 1,2 또는 1,2,3"
read -r -p "선택 [기본값: 1]: " _PROV_SEL
_PROV_SEL="${_PROV_SEL:-1}"

# 선택된 프로바이더 파싱
HAS_ANTHROPIC=false; HAS_GEMINI=false; HAS_CODEX=false; HAS_CEREBRAS=false
IFS=',' read -ra _PROVS <<< "$_PROV_SEL"
for _p in "${_PROVS[@]}"; do
  _p="${_p// /}"
  case "$_p" in
    1) HAS_ANTHROPIC=true ;;
    2) HAS_GEMINI=true ;;
    3) HAS_CODEX=true ;;
    4) HAS_CEREBRAS=true ;;
  esac
done

# ── ultracode 옵션 (기본값 false — 필요 시 settings.json에서 수동 활성화) ────
ULTRACODE_ENABLED=false

# Gemini API 키 설정
GEMINI_API_KEY_VAL=""
if $HAS_GEMINI; then
  # 자동 감지: ~/.codex/config.toml
  _AUTO_KEY=$(python3 -c "
import pathlib, re, sys
p = pathlib.Path.home() / '.codex/config.toml'
if p.exists():
    m = re.search(r'GEMINI_API_KEY\s*=\s*[\"\'](.*?)[\"\']', p.read_text())
    print(m.group(1) if m else '')
" 2>/dev/null)
  if [ -n "$_AUTO_KEY" ]; then
    echo "   ✅ Gemini API 키 자동 감지됨 (~/.codex/config.toml)"
    GEMINI_API_KEY_VAL="$_AUTO_KEY"
  else
    echo "   Gemini API 키를 입력하세요 (aistudio.google.com에서 발급):"
    read -r -p "   GEMINI_API_KEY> " GEMINI_API_KEY_VAL
    if [ -n "$GEMINI_API_KEY_VAL" ]; then
      echo "   export GEMINI_API_KEY='$GEMINI_API_KEY_VAL'" >> "$TARGET/.collar/.env"
      echo "   ⚠️  .collar/.env에 저장됨 (git 추적 제외 확인 필요)"
    fi
  fi
  echo ""
fi

# Cerebras API 키 설정
CEREBRAS_API_KEY_VAL=""
if $HAS_CEREBRAS; then
  echo "   ⚠️  Cerebras는 TEST ONLY — 프로덕션 라우팅에 포함되지 않습니다."
  if [ -n "${CEREBRAS_API_KEY:-}" ]; then
    echo "   ✅ CEREBRAS_API_KEY 환경변수 감지됨"
    CEREBRAS_API_KEY_VAL="${CEREBRAS_API_KEY}"
  else
    echo "   CEREBRAS_API_KEY를 입력하세요:"
    read -r -p "   CEREBRAS_API_KEY> " CEREBRAS_API_KEY_VAL
  fi
  echo ""
fi

# 프로바이더 가용성 테스트
echo "🔍 프로바이더 연결 확인 중..."
PROVIDER_STATUS="{}"
if $HAS_ANTHROPIC; then
  if command -v claude &>/dev/null; then
    echo "   ✅ Claude CLI 감지 ($(claude --version 2>/dev/null | head -1 || echo 'ok'))"
    PROVIDER_STATUS=$(echo "$PROVIDER_STATUS" | python3 -c "import sys,json; d=json.load(sys.stdin); d['anthropic']='ok'; print(json.dumps(d))")
  else
    echo "   ❌ Claude CLI 없음 — claude 명령어 설치 필요"
    HAS_ANTHROPIC=false
  fi
fi
if $HAS_GEMINI && [ -n "$GEMINI_API_KEY_VAL" ]; then
  _TEST=$(curl -s --max-time 5 \
    "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent?key=$GEMINI_API_KEY_VAL" \
    -H "Content-Type: application/json" \
    -d '{"contents":[{"parts":[{"text":"hi"}]}]}' 2>/dev/null | python3 -c "
import sys,json
try:
    d=json.load(sys.stdin)
    print('ok' if 'candidates' in d else 'error:'+d.get('error',{}).get('message','?')[:40])
except: print('error:parse')
")
  if [[ "$_TEST" == "ok" ]]; then
    echo "   ✅ Gemini API 연결 성공 (gemini-2.5-flash-lite)"
    PROVIDER_STATUS=$(echo "$PROVIDER_STATUS" | python3 -c "import sys,json; d=json.load(sys.stdin); d['gemini']='ok'; print(json.dumps(d))")
  else
    echo "   ⚠️  Gemini API 오류: $_TEST"
  fi
fi
if $HAS_CODEX; then
  if command -v codex &>/dev/null; then
    echo "   ✅ Codex CLI 감지"
    PROVIDER_STATUS=$(echo "$PROVIDER_STATUS" | python3 -c "import sys,json; d=json.load(sys.stdin); d['codex']='ok'; print(json.dumps(d))")
  else
    echo "   ❌ Codex CLI 없음"
    HAS_CODEX=false
  fi
fi
echo ""

# 라우팅 설정 생성
_SIMPLE_PROVIDER="anthropic"; _SIMPLE_MODEL="claude-haiku-4-5-20251001"
_STANDARD_PROVIDER="anthropic"; _STANDARD_MODEL="claude-sonnet-4-6"
_COMPLEX_PROVIDER="anthropic"; _COMPLEX_MODEL="claude-opus-4-7"

# 최적 라우팅: Gemini 있으면 simple에 사용
if $HAS_GEMINI && [ -n "$GEMINI_API_KEY_VAL" ] && [[ "$PROVIDER_STATUS" == *'"gemini":"ok"'* ]]; then
  _SIMPLE_PROVIDER="gemini"; _SIMPLE_MODEL="gemini-2.5-flash-lite"
fi
# Claude 없으면 강등
if ! $HAS_ANTHROPIC; then
  if $HAS_CODEX; then
    _STANDARD_PROVIDER="codex"; _STANDARD_MODEL="gpt-5.5"
    _COMPLEX_PROVIDER="codex"; _COMPLEX_MODEL="gpt-5.5"
  elif $HAS_GEMINI; then
    _STANDARD_PROVIDER="gemini"; _STANDARD_MODEL="gemini-2.5-flash-lite"
    _COMPLEX_PROVIDER="gemini"; _COMPLEX_MODEL="gemini-2.5-flash-lite"
  fi
fi

echo "📋 라우팅 설정:"
echo "   simple  → $_SIMPLE_PROVIDER / $_SIMPLE_MODEL"
echo "   standard→ $_STANDARD_PROVIDER / $_STANDARD_MODEL"
echo "   complex → $_COMPLEX_PROVIDER / $_COMPLEX_MODEL"
echo ""

# 프로바이더 목록 JSON
_PROVIDERS_JSON=$(python3 -c "
import json
provs = {}
has_a, has_g, has_c = $([ "$HAS_ANTHROPIC" = true ] && echo True || echo False), $([ "$HAS_GEMINI" = true ] && echo True || echo False), $([ "$HAS_CODEX" = true ] && echo True || echo False)
if has_a: provs['anthropic'] = {'type':'claude-cli','subscription':'Claude Max'}
if has_g: provs['gemini'] = {'type':'gemini-api','subscription':'Gemini Pro','api_key':'${GEMINI_API_KEY_VAL:0:8}...'}
if has_c: provs['codex'] = {'type':'codex-cli','subscription':'ChatGPT Pro'}
print(json.dumps(provs, ensure_ascii=False))
")

# ── 프로젝트 타입 감지 ──────────────────────────────────────────
detect_type() {
  if [ -f "$TARGET/package.json" ]; then
    if grep -q '"next"' "$TARGET/package.json" 2>/dev/null; then echo "nextjs"
    elif grep -q '"react"' "$TARGET/package.json" 2>/dev/null; then echo "react"
    elif grep -q '"express"\|"fastify"\|"hono"' "$TARGET/package.json" 2>/dev/null; then echo "nodejs-api"
    else echo "nodejs"
    fi
  elif [ -f "$TARGET/pyproject.toml" ] || [ -f "$TARGET/requirements.txt" ] || [ -f "$TARGET/setup.py" ]; then
    echo "python"
  elif [ -f "$TARGET/Cargo.toml" ]; then
    echo "rust"
  elif [ -f "$TARGET/go.mod" ]; then
    echo "go"
  elif [ -f "$TARGET/Package.swift" ] || \
       find "$TARGET" -maxdepth 1 -name "*.xcodeproj" -o -name "*.xcworkspace" 2>/dev/null | grep -q .; then
    echo "swift"
  elif find "$TARGET" -maxdepth 2 -name "*.kt" 2>/dev/null | grep -q . || \
       [ -f "$TARGET/build.gradle.kts" ] || [ -f "$TARGET/settings.gradle.kts" ]; then
    echo "kotlin"
  elif [ -f "$TARGET/pom.xml" ] || [ -f "$TARGET/build.gradle" ]; then
    echo "java"
  elif [ -f "$TARGET/Makefile" ] || [ -f "$TARGET/makefile" ]; then
    echo "bash"
  elif find "$TARGET" -maxdepth 2 -name "*.sh" 2>/dev/null | grep -q .; then
    echo "bash"
  elif [ -d "$TARGET/bin" ] && \
       find "$TARGET/bin" -maxdepth 1 -type f -not -name ".*" 2>/dev/null | \
       xargs -I{} head -1 {} 2>/dev/null | grep -q "^#!/.*bash\|^#!/.*sh"; then
    echo "bash"
  else
    echo "generic"
  fi
}

PROJECT_TYPE="$(detect_type)"
echo "📦 프로젝트 타입: $PROJECT_TYPE"

# ── 타입별 설정 ─────────────────────────────────────────────────
case "$PROJECT_TYPE" in
  nextjs|react|nodejs*|nodejs)
    TECH_STACK="Node.js / TypeScript"
    VERIFY_COMMAND="pnpm typecheck && pnpm test:run && pnpm build"
    DEV_COMMAND_1="pnpm dev"
    DEV_COMMAND_2="pnpm build"
    DOMAIN_TABLE="| UI 컴포넌트/페이지 | frontend | sonnet |\n| API 라우트/서비스 | backend | sonnet |\n| 스키마/마이그레이션 | database | sonnet |"
    ;;
  python)
    TECH_STACK="Python"
    VERIFY_COMMAND="uv run pytest && uv run mypy ."
    DEV_COMMAND_1="uv run python -m app"
    DEV_COMMAND_2="uv build"
    DOMAIN_TABLE="| 비즈니스 로직 | executor | sonnet |\n| 데이터/DB | database | sonnet |"
    ;;
  rust)
    TECH_STACK="Rust"
    VERIFY_COMMAND="cargo test && cargo clippy && cargo build --release"
    DEV_COMMAND_1="cargo run"
    DEV_COMMAND_2="cargo build --release"
    DOMAIN_TABLE="| 코어 로직 | executor | sonnet |"
    ;;
  go)
    TECH_STACK="Go"
    VERIFY_COMMAND="go test ./... && go vet ./... && go build ./..."
    DEV_COMMAND_1="go run ."
    DEV_COMMAND_2="go build -o bin/app ."
    DOMAIN_TABLE="| 비즈니스 로직 | executor | sonnet |"
    ;;
  swift)
    TECH_STACK="Swift"
    VERIFY_COMMAND="swift build && swift test"
    DEV_COMMAND_1="swift run"
    DEV_COMMAND_2="swift build -c release"
    DOMAIN_TABLE="| 앱 로직 | executor | sonnet |\n| UI (SwiftUI) | designer | sonnet |"
    ;;
  kotlin)
    TECH_STACK="Kotlin"
    VERIFY_COMMAND="./gradlew test && ./gradlew build"
    DEV_COMMAND_1="./gradlew run"
    DEV_COMMAND_2="./gradlew build"
    DOMAIN_TABLE="| 비즈니스 로직 | executor | sonnet |\n| Android UI | designer | sonnet |"
    ;;
  bash)
    TECH_STACK="Bash / Shell"
    # 루트 .sh 파일 또는 Makefile 기반
    MAIN_SCRIPT="$(find "$TARGET" -maxdepth 1 -name "*.sh" | head -1 | xargs basename 2>/dev/null || echo "script.sh")"
    VERIFY_COMMAND="bash -n bin/*.sh && shellcheck bin/*.sh 2>/dev/null || bash -n $MAIN_SCRIPT"
    DEV_COMMAND_1="bash $MAIN_SCRIPT"
    DEV_COMMAND_2="make 2>/dev/null || bash $MAIN_SCRIPT"
    DOMAIN_TABLE="| 스크립트 로직 (bin/) | executor | sonnet |\n| 템플릿 작성 | executor | sonnet |"
    ;;
  *)
    TECH_STACK="(직접 기입)"
    VERIFY_COMMAND="# 검증 명령어를 직접 입력하세요"
    DEV_COMMAND_1="# 실행 명령어"
    DEV_COMMAND_2="# 빌드 명령어"
    DOMAIN_TABLE="| 도메인 | 에이전트 | 모델 |"
    ;;
esac

# ── 레포 구조 자동 감지 ─────────────────────────────────────────
REPO_STRUCTURE="$(
  find "$TARGET" -maxdepth 2 -not -path '*/node_modules/*' \
    -not -path '*/.git/*' \
    -not -path '*/__pycache__/*' \
    -not -path '*/target/*' \
    -not -name '*.log' \
    -not -name '.DS_Store' \
    | sort \
    | sed "s|$TARGET||" \
    | sed 's|^/||' \
    | head -30 \
    | sed 's|^|  |'
)"

# ── 템플릿 렌더 함수 (Python으로 멀티라인 처리) ──────────────────
render_template() {
  local tmpl="$1"
  local out="$2"
  python3 - "$tmpl" "$out" \
    "$PROJECT_NAME" "$TECH_STACK" "$VERIFY_COMMAND" \
    "$DEV_COMMAND_1" "$DEV_COMMAND_2" "$REPO_STRUCTURE" \
    "$PROJECT_GOAL" "$COLLAR_LANG" "$DB_SCHEMA" << 'PYEOF'
import sys, pathlib

tmpl_path, out_path = sys.argv[1], sys.argv[2]
proj, stack, verify, dev1, dev2, repo = sys.argv[3], sys.argv[4], sys.argv[5], sys.argv[6], sys.argv[7], sys.argv[8]
goal, lang, db_schema = sys.argv[9], sys.argv[10], sys.argv[11]

lang_instruction = {
    "ko": "모든 작업 안내, 설명, 보고는 **한국어**로 한다.",
    "en": "All task guidance, explanations, and reports must be in **English**.",
    "ja": "すべての作業案内・説明・報告は**日本語**で行う。",
    "zh": "所有任务说明、解释和报告均使用**中文**。",
}.get(lang, "모든 작업 안내, 설명, 보고는 **한국어**로 한다.")

text = pathlib.Path(tmpl_path).read_text()
text = text.replace("{{PROJECT_NAME}}", proj)
text = text.replace("{{PROJECT_DESCRIPTION}}", goal)
text = text.replace("{{PROJECT_PURPOSE}}", goal)
text = text.replace("{{TECH_STACK}}", stack)
text = text.replace("{{VERIFY_COMMAND}}", verify)
text = text.replace("{{DEV_COMMAND_1}}", dev1)
text = text.replace("{{DEV_COMMAND_2}}", dev2)
text = text.replace("{{REPO_STRUCTURE}}", repo)
text = text.replace("{{SETUP_COMMANDS}}", dev1)
text = text.replace("{{DOMAIN_1}}", "도메인 1")
text = text.replace("{{AGENT_1}}", "executor")
text = text.replace("{{LANGUAGE_INSTRUCTION}}", lang_instruction)
text = text.replace("{{DB_SCHEMA}}", db_schema)
pathlib.Path(out_path).write_text(text)
PYEOF
}

# ── CLAUDE.md 생성 ───────────────────────────────────────────────
CLAUDE_OUT="$TARGET/CLAUDE.md"

if [ -f "$CLAUDE_OUT" ]; then
  echo "⚠️  CLAUDE.md 이미 존재. 덮어쓰지 않음."
  echo "   수동으로 병합하거나 --force 플래그 추가"
else
  render_template "$COLLAR_HOME/templates/CLAUDE.md.base" "$CLAUDE_OUT"
  echo "✅ CLAUDE.md 생성: $CLAUDE_OUT"
fi

# ── AGENTS.md 생성 ───────────────────────────────────────────────
AGENTS_OUT="$TARGET/AGENTS.md"

if [ -f "$AGENTS_OUT" ]; then
  echo "⚠️  AGENTS.md 이미 존재. 건너뜀."
else
  render_template "$COLLAR_HOME/templates/AGENTS.md.base" "$AGENTS_OUT"
  echo "✅ AGENTS.md 생성: $AGENTS_OUT"
fi

# ── .collar/collar-dispatcher.sh 설치 ───────────────────────────
DISPATCHER_SRC="$COLLAR_HOME/templates/collar-dispatcher.sh"
DISPATCHER_OUT="$TARGET/.collar/collar-dispatcher.sh"
mkdir -p "$TARGET/.collar"

if [ ! -f "$DISPATCHER_OUT" ] && [ -f "$DISPATCHER_SRC" ]; then
  cp "$DISPATCHER_SRC" "$DISPATCHER_OUT"
  chmod +x "$DISPATCHER_OUT"
  echo "✅ .collar/collar-dispatcher.sh 설치"
fi

# ── .claude/settings.json (훅 포함) ──────────────────────────────
mkdir -p "$TARGET/.claude"
SETTINGS_OUT="$TARGET/.claude/settings.json"
DISPATCHER_ABS="$TARGET/.collar/collar-dispatcher.sh"

if [ ! -f "$SETTINGS_OUT" ]; then
  python3 - << PYEOF
import json, pathlib

dispatcher = "${DISPATCHER_ABS}"
settings = {
  "permissions": {
    "allow": ["Bash(git *)", "Bash(pnpm *)", "Bash(npm *)", "Bash(uv *)"],
    "deny":  ["Bash(rm -rf /)", "Bash(curl * | bash)", "Bash(wget * | sh)"]
  },
  "hooks": {
    "PreToolUse":      [{"hooks": [{"type": "command", "command": f"bash '{dispatcher}'", "timeout": 10}]}],
    "UserPromptSubmit":[{"hooks": [{"type": "command", "command": f"bash '{dispatcher}'", "timeout": 60}]}],
    "SessionStart":    [{"hooks": [{"type": "command", "command": f"bash '{dispatcher}'", "timeout": 30}]}],
    "PostToolUse":     [{"hooks": [{"type": "command", "command": f"bash '{dispatcher}'", "timeout": 60}]}]
  }
}

if "${ULTRACODE_ENABLED}" == "true":
    settings["ultracode"] = True
    settings["model"] = "claude-opus-4-8"

pathlib.Path("${SETTINGS_OUT}").write_text(json.dumps(settings, indent=2, ensure_ascii=False) + "\n")
PYEOF
  UC_MSG=$([ "$ULTRACODE_ENABLED" = "true" ] && echo " + ultracode(Opus)" || echo "")
  echo "✅ .claude/settings.json 생성 (훅 포함${UC_MSG})"
fi

# ── .npmrc (패키지 공급망 보안) ──────────────────────────────────────
NPMRC_OUT="$TARGET/.npmrc"

if [ ! -f "$NPMRC_OUT" ]; then
  cat > "$NPMRC_OUT" << 'EOF'
min-release-age=3
ignore-scripts=true
EOF
  echo "✅ .npmrc 생성 (min-release-age=3, ignore-scripts=true)"
fi

# ── .collar/project-facts.md (환경 정보 — 세션마다 AI가 읽음) ───────
FACTS_OUT="$TARGET/.collar/project-facts.md"
mkdir -p "$TARGET/.collar"

if [ ! -f "$FACTS_OUT" ]; then
  set +e  # 감지 중 grep no-match 등이 set -e를 트리거하지 않도록
  _FACTS_DATE=$(date +%Y-%m-%d)

  # ── 포트 감지 ──────────────────────────────────────────────────
  _PORT="TODO: 개발 서버 포트 (예: 3000)"
  for _ef in "$TARGET/.env.local" "$TARGET/.env"; do
    if [ -f "$_ef" ]; then
      _v=$(grep -E '^PORT=' "$_ef" 2>/dev/null | head -1 | cut -d= -f2 | tr -d '"'"'" | tr -d ' ')
      if [ -n "$_v" ]; then _PORT="$_v"; break; fi
    fi
  done
  if [ "$_PORT" = "TODO: 개발 서버 포트 (예: 3000)" ] && [ -f "$TARGET/package.json" ]; then
    _v=$(python3 -c "
import json, re
try:
    p = json.load(open('$TARGET/package.json'))
    for v in p.get('scripts', {}).values():
        m = re.search(r'PORT=(\d{3,5})', str(v))
        if m: print(m.group(1)); exit()
    print('')
except: print('')
" 2>/dev/null)
    if [ -n "$_v" ]; then _PORT="$_v"; fi
  fi
  if [ "$PROJECT_TYPE" = "nextjs" ] && [ "$_PORT" = "TODO: 개발 서버 포트 (예: 3000)" ]; then
    _PORT="3000"
  fi

  # ── DB 감지 ────────────────────────────────────────────────────
  _DB_TYPE="(없음)"
  _DB_URL_MASKED=""
  _DB_ORM="(없음)"

  for _ef in "$TARGET/.env.local" "$TARGET/.env"; do
    if [ -f "$_ef" ]; then
      _raw=$(grep -E '^DATABASE_URL=' "$_ef" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '"'"'")
      if [ -n "$_raw" ]; then
        if echo "$_raw" | grep -qi "postgres"; then _DB_TYPE="PostgreSQL"
        elif echo "$_raw" | grep -qi "mysql";  then _DB_TYPE="MySQL"
        elif echo "$_raw" | grep -qi "sqlite"; then _DB_TYPE="SQLite"
        elif echo "$_raw" | grep -qi "mongodb"; then _DB_TYPE="MongoDB"
        elif echo "$_raw" | grep -qi "redis";  then _DB_TYPE="Redis"
        fi
        _DB_URL_MASKED=$(echo "$_raw" | sed 's|:[^:@/][^:@/]*@|:***@|g')
        break
      fi
    fi
  done

  # ORM 감지
  if [ -f "$TARGET/prisma/schema.prisma" ]; then
    _DB_ORM="Prisma"
    if [ "$_DB_TYPE" = "(없음)" ]; then
      _prov=$(grep -E '^\s*provider\s*=' "$TARGET/prisma/schema.prisma" 2>/dev/null | head -1 | cut -d'"' -f2)
      case "$_prov" in
        postgresql|postgres) _DB_TYPE="PostgreSQL" ;;
        mysql)   _DB_TYPE="MySQL" ;;
        sqlite)  _DB_TYPE="SQLite" ;;
        mongodb) _DB_TYPE="MongoDB" ;;
      esac
    fi
  fi
  if [ -f "$TARGET/drizzle.config.ts" ] || [ -f "$TARGET/drizzle.config.js" ]; then _DB_ORM="Drizzle"; fi
  if [ -f "$TARGET/typeorm.config.ts" ] || [ -f "$TARGET/ormconfig.json" ]; then _DB_ORM="TypeORM"; fi
  if [ -f "$TARGET/manage.py" ]; then _DB_ORM="Django ORM"; fi

  # ── 패키지 매니저 ──────────────────────────────────────────────
  _PKG_MGR="npm"
  if [ -f "$TARGET/pnpm-lock.yaml" ]; then _PKG_MGR="pnpm"
  elif [ -f "$TARGET/yarn.lock" ]; then _PKG_MGR="yarn"
  elif [ -f "$TARGET/bun.lockb" ]; then _PKG_MGR="bun"
  fi

  # ── 주요 명령어 ────────────────────────────────────────────────
  _CMD_DEV="TODO"; _CMD_BUILD="TODO"; _CMD_TEST="TODO"; _CMD_DB=""
  if [ -f "$TARGET/package.json" ]; then
    _CMD_DEV=$(python3   -c "import json; p=json.load(open('$TARGET/package.json')); s=p.get('scripts',{}); print(s.get('dev', s.get('start','TODO')))" 2>/dev/null || echo "TODO")
    _CMD_BUILD=$(python3 -c "import json; p=json.load(open('$TARGET/package.json')); print(p.get('scripts',{}).get('build','TODO'))" 2>/dev/null || echo "TODO")
    _CMD_TEST=$(python3  -c "import json; p=json.load(open('$TARGET/package.json')); print(p.get('scripts',{}).get('test','TODO'))"  2>/dev/null || echo "TODO")
    _CMD_DB=$(python3    -c "
import json
try:
    s = json.load(open('$TARGET/package.json')).get('scripts', {})
    for k in ['migrate','db:migrate','db:push','db:generate','migration']:
        if k in s: print(f'$_PKG_MGR run {k}'); exit()
    print('')
except: print('')
" 2>/dev/null)
  elif [ -f "$TARGET/Makefile" ]; then
    _CMD_DEV="make dev"; _CMD_BUILD="make build"; _CMD_TEST="make test"
  elif [ -f "$TARGET/pyproject.toml" ] || [ -f "$TARGET/requirements.txt" ]; then
    _CMD_DEV="uvicorn main:app --reload (또는 python manage.py runserver)"
    _CMD_TEST="pytest"
  fi

  # ── 서비스 (docker-compose) ────────────────────────────────────
  _SERVICES_BLOCK=""
  for _cf in "$TARGET/docker-compose.yml" "$TARGET/docker-compose.yaml"; do
    if [ -f "$_cf" ]; then
      _SERVICES_BLOCK=$(python3 -c "
try:
    import yaml
    d = yaml.safe_load(open('$_cf'))
    for name, svc in d.get('services', {}).items():
        ports = svc.get('ports', [])
        port_str = ' (포트: ' + str(ports[0]) + ')' if ports else ''
        img = svc.get('image', '')
        img_str = ' [' + img + ']' if img else ''
        print(f'- {name}{port_str}{img_str}')
except ImportError:
    import re
    for line in open('$_cf'):
        m = re.match(r'^  ([a-zA-Z][\w-]+):\s*$', line)
        if m: print(f'- {m.group(1)}')
except Exception as e:
    print('(파싱 오류)')
" 2>/dev/null)
      break
    fi
  done

  # ── 환경변수 키 목록 ───────────────────────────────────────────
  _ENV_KEYS_BLOCK="(없음)"
  for _ef in "$TARGET/.env.example" "$TARGET/.env.sample" "$TARGET/.env"; do
    if [ -f "$_ef" ]; then
      _keys=$(grep -E '^[A-Z_][A-Z0-9_]*=' "$_ef" 2>/dev/null | cut -d= -f1 | head -30 | sed 's/^/- /')
      [ -n "$_keys" ] && { _ENV_KEYS_BLOCK="$_keys"; break; }
    fi
  done

  # ── 파일 작성 ──────────────────────────────────────────────────
  {
    echo "# Project Facts — $PROJECT_NAME"
    echo "> 세션 시작 시 **반드시** 읽어라. 포트, DB, 스택, 명령어 등 핵심 환경 정보."
    echo "> 내용이 바뀌면 이 파일을 직접 수정하라."
    echo "> 생성: $_FACTS_DATE | 스택: $PROJECT_TYPE"
    echo ""
    echo "---"
    echo ""
    echo "## 서버 / 포트"
    echo ""
    if echo "$_PORT" | grep -q "TODO"; then
      echo "- **Dev 서버:** TODO — .env의 PORT 또는 package.json scripts에서 확인 후 기입"
    else
      echo "- **Dev 서버:** http://localhost:$_PORT"
      echo "- **API 베이스:** http://localhost:$_PORT"
    fi
    echo ""
    echo "---"
    echo ""
    echo "## 데이터베이스"
    echo ""
    echo "- **종류:** $_DB_TYPE"
    echo "- **ORM / 클라이언트:** $_DB_ORM"
    [ -n "$_DB_URL_MASKED" ] && echo "- **연결 (마스킹):** \`$_DB_URL_MASKED\`"
    echo "- **이 프로젝트 스키마:** \`$DB_SCHEMA\` ← 이 스키마에만 읽기·쓰기. 다른 프로젝트 스키마 접근 금지"
    echo ""
    echo "---"
    echo ""
    echo "## 스택"
    echo ""
    echo "- **프레임워크 / 타입:** $PROJECT_TYPE"
    echo "- **패키지 매니저:** $_PKG_MGR"
    echo ""
    echo "---"
    echo ""
    echo "## 주요 명령어"
    echo ""
    echo '```sh'
    echo "$_PKG_MGR run dev    # 개발 서버    → $_CMD_DEV"
    echo "$_PKG_MGR run build  # 빌드         → $_CMD_BUILD"
    echo "$_PKG_MGR run test   # 테스트       → $_CMD_TEST"
    [ -n "$_CMD_DB" ] && echo "$_CMD_DB   # DB 마이그레이션"
    echo '```'
    if [ -n "$_SERVICES_BLOCK" ]; then
      echo ""
      echo "---"
      echo ""
      echo "## 서비스 구성 (docker-compose)"
      echo ""
      echo "$_SERVICES_BLOCK"
    fi
    echo ""
    echo "---"
    echo ""
    echo "## 환경변수 키 목록"
    echo ""
    echo "$_ENV_KEYS_BLOCK"
    echo ""
    echo "---"
    echo ""
    echo "## 메모 (AI가 세션 중 발견한 추가 사실)"
    echo ""
    echo "(포트 변경, 특이사항, 주의할 설정 등을 여기에 기록)"
  } > "$FACTS_OUT"

  set -e  # 감지 완료 — set -e 복원
  echo "✅ .collar/project-facts.md 생성 (포트: ${_PORT}, DB: ${_DB_TYPE}, ORM: ${_DB_ORM})"
fi

# ── .collar/memory.md (프로젝트 메모리) ─────────────────────────────
mkdir -p "$TARGET/.collar"
MEMORY_OUT="$TARGET/.collar/memory.md"

if [ ! -f "$MEMORY_OUT" ]; then
  cat > "$MEMORY_OUT" << MEMORY_EOF
# Project Memory — $PROJECT_NAME
마지막 업데이트: $(date +%Y-%m-%d)

> **이 파일은 지도(map)다 — 백과사전이 아니다.**
> 실제 내용은 개별 파일에 둔다. 여기에는 포인터(링크·경로)만 기록한다.
> 내용을 직접 여기에 쓰지 말 것 — 파일이 커지면 AI가 전체를 읽지 못한다.

AI가 이 파일을 세션 시작 시 **반드시** 읽는다. 목표를 잊지 않고 작업 방향을 유지하기 위해 항상 이 파일을 먼저 확인한다.

---

## 🎯 프로젝트 목표 (변경 시 사용자에게 확인 필요)

$PROJECT_GOAL

---

## ⚙️ 설정

- 언어: $LANG_LABEL ($COLLAR_LANG)
- 초기화: $(date +%Y-%m-%d)

---

## 반복 실패 → 운영 규칙 파이프라인

같은 실수가 반복됐을 때 → 패턴을 운영 규칙으로 굳혀 재발을 막는다.
발견 즉시 \`collar remember "규칙"\` 실행 또는 아래에 포인터 추가.

| 날짜 | 실패 패턴 | 굳힌 규칙 | 파일 |
|------|---------|---------|------|
| (여기에 기록) | | | |

---

## 발견된 패턴 (포인터 목록)

(패턴 발견 시 내용을 여기에 직접 쓰지 말고, 별도 파일 만들고 포인터만 추가)
(예: \`- [인증 오류 처리](./patterns/auth-error.md) — JWT 만료 시 refresh 먼저\`)

---

## 작업 이력 요약 (포인터 목록)

(중요한 의사결정·아키텍처 변경은 별도 파일로, 여기엔 링크만)

MEMORY_EOF
  echo "✅ .collar/memory.md 생성 (프로젝트 목표 + 메모리)"
fi

# ── .collar/config.json ──────────────────────────────────────────
CONFIG_OUT="$TARGET/.collar/config.json"
if [ ! -f "$CONFIG_OUT" ]; then
  python3 - "$CONFIG_OUT" \
    "$PROJECT_NAME" "$PROJECT_GOAL" "$COLLAR_LANG" "$PROJECT_TYPE" \
    "$_SIMPLE_PROVIDER" "$_SIMPLE_MODEL" \
    "$_STANDARD_PROVIDER" "$_STANDARD_MODEL" \
    "$_COMPLEX_PROVIDER" "$_COMPLEX_MODEL" \
    "$ULTRACODE_ENABLED" << PYEOF
import sys, json, datetime

out = sys.argv[1]
proj, goal, lang, ptype = sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5]
s_prov, s_model = sys.argv[6], sys.argv[7]
t_prov, t_model = sys.argv[8], sys.argv[9]
c_prov, c_model = sys.argv[10], sys.argv[11]
ultracode = sys.argv[12] == "true"

config = {
  "project": proj,
  "goal": goal,
  "language": lang,
  "type": ptype,
  "created": datetime.date.today().isoformat(),
  "ultracode": ultracode,
  "routing": {
    "simple":   {"provider": s_prov, "model": s_model},
    "standard": {"provider": t_prov, "model": t_model},
    "complex":  {"provider": c_prov, "model": c_model}
  }
}
import pathlib
pathlib.Path(out).write_text(json.dumps(config, ensure_ascii=False, indent=2))
PYEOF
  echo "✅ .collar/config.json 생성 (언어: $LANG_LABEL, 라우팅: ${_SIMPLE_PROVIDER}→${_STANDARD_PROVIDER}→${_COMPLEX_PROVIDER})"
fi

# ── .collar/tasks/ 생성 (요청사항 체크리스트 추적용) ───────────────
mkdir -p "$TARGET/.collar/tasks"
echo "✅ .collar/tasks/ 생성 (요청 체크리스트 문서 저장소)"

# ── .collar/hooks 설치 (collar-hooks 템플릿) ─────────────────────
mkdir -p "$TARGET/.collar/hooks"
HOOKS_SRC="$COLLAR_HOME/templates/collar-hooks"
HOOKS_INSTALLED=0

if [ -d "$HOOKS_SRC" ]; then
  for hook_file in "$HOOKS_SRC"/*.sh; do
    [ -f "$hook_file" ] || continue
    hook_name="$(basename "$hook_file")"
    hook_dest="$TARGET/.collar/hooks/$hook_name"
    if [ ! -f "$hook_dest" ]; then
      cp "$hook_file" "$hook_dest"
      chmod +x "$hook_dest"
      HOOKS_INSTALLED=$((HOOKS_INSTALLED + 1))
    fi
  done
  [ "$HOOKS_INSTALLED" -gt 0 ] && echo "✅ .collar/hooks 설치: ${HOOKS_INSTALLED}개 훅"
fi

# ── 글로벌 룰 승격 체크 ────────────────────────────────────────────
GLOBAL_CLAUDE="$HOME/.claude/CLAUDE.md"

if [ -f "$GLOBAL_CLAUDE" ]; then
  if ! grep -q "STARTED / TESTED / VERIFIED" "$GLOBAL_CLAUDE" 2>/dev/null; then
    echo ""
    echo "━━━ 글로벌 룰 승격 체크 ━━━"
    echo ""
    echo "다음 규칙들이 모든 프로젝트에 적용되면 유익합니다:"
    echo "  • 완료 3단계 (STARTED / TESTED / VERIFIED)"
    echo "  • 모호한 표현 차단 (효율적으로, 잘, 이전처럼 등)"
    echo "  • 다음 단계 명시 프로토콜"
    echo "  • 재발 버그 체크"
    echo ""
    echo "현재 ~/.claude/CLAUDE.md에 이 규칙들이 없습니다."
    echo ""
    if [ -t 0 ]; then
      echo "  [y] 그대로 추가"
      echo "  [e] 의견/메모 입력 후 추가 (왜 추가하는지, 수정할 내용 등)"
      echo "  [v] 추가될 내용 미리보기"
      echo "  [n] 건너뜀 (기본)"
      echo ""
      read -p "선택 [y/e/v/N]: " GLOBAL_CONFIRM
    else
      GLOBAL_CONFIRM="n"
      echo "(비대화형 실행: 글로벌 추가를 건너뜁니다. 직접 실행하려면: collar-init --promote-global)"
    fi

    # 미리보기
    if [ "$GLOBAL_CONFIRM" = "v" ] || [ "$GLOBAL_CONFIRM" = "V" ]; then
      echo ""
      echo "── 추가될 내용 미리보기 ──────────────────────────────"
      echo "## AI 협업 완료 프로토콜 (모든 프로젝트 공통)"
      echo ""
      echo "• 완료 3단계: STARTED / TESTED / VERIFIED"
      echo "• 모호한 표현 차단: 효율적으로, 잘, 이전처럼, 비슷하게"
      echo "• 다음 단계 명시: '완료: X / 현재상태: Y / 다음: Z / 진행할까요?'"
      echo "• 재발 버그 체크: 이전 수정 생존 확인 우선"
      echo "─────────────────────────────────────────────────────"
      echo ""
      read -p "추가할까요? [y/e/N]: " GLOBAL_CONFIRM
    fi

    # 의견/메모 입력
    GLOBAL_NOTE=""
    if [ "$GLOBAL_CONFIRM" = "e" ] || [ "$GLOBAL_CONFIRM" = "E" ]; then
      echo ""
      echo "의견/메모를 입력하세요 (글로벌 CLAUDE.md에 주석으로 저장됩니다):"
      echo "예: '2026-05-14 모든 프로젝트에 유용해서 추가' / '4번째 규칙은 필요 없다고 생각'"
      read -p "> " GLOBAL_NOTE
      GLOBAL_CONFIRM="y"
    fi

    if [ "$GLOBAL_CONFIRM" = "y" ] || [ "$GLOBAL_CONFIRM" = "Y" ]; then
      # 메모가 있으면 먼저 추가
      if [ -n "$GLOBAL_NOTE" ]; then
        echo "" >> "$GLOBAL_CLAUDE"
        echo "<!-- collar 승격 메모 ($(date +%Y-%m-%d)): $GLOBAL_NOTE -->" >> "$GLOBAL_CLAUDE"
      fi
      cat >> "$GLOBAL_CLAUDE" << 'GLOBAL_RULES_EOF'

## AI 협업 완료 프로토콜 (모든 프로젝트 공통)

### 완료 3단계 프로토콜

"완료"를 말하기 전에 반드시 어느 단계인지 명시:

| 단계 | 의미 |
|------|------|
| **STARTED** | 코드 변경만, 미검증 |
| **TESTED** | 로컬 빌드/테스트 통과, UI 확인 |
| **VERIFIED** | 실제 환경에서 동작 확인 |

STARTED 상태에서 "완료"라고 말하는 것은 금지.

### 모호한 표현 차단

다음 표현이 요구사항에 있으면 코드 전에 구체화 요청:
- "효율적으로", "잘", "좋게" → 구체적으로 어떻게?
- "이전처럼", "아까처럼" → 정확히 어느 시점?
- "비슷하게", "느낌으로" → 실제 예시?

### 다음 단계 명시 프로토콜

작업 완료 후 반드시:
```
완료: [무엇을 했는지]
현재 상태: TESTED
다음: [구체적인 다음 단계]
진행할까요?
```

### 재발 버그 체크

이미 수정했다고 보고한 버그가 다시 보고되면:
1. 이전 수정이 실제로 적용됐는지 먼저 확인
2. 수정이 살아있음을 증명
3. 수정이 사라진 원인 추적 후 보고
GLOBAL_RULES_EOF
      echo "✅ 글로벌 규칙 추가 완료: $GLOBAL_CLAUDE"
    fi
  else
    echo ""
    echo "✅ 글로벌 규칙 이미 반영됨 (~/.claude/CLAUDE.md)"
  fi
fi

# ── collar-watchdog 자동 설치 ────────────────────────────────────
echo ""
echo "━━━ watchdog 설치 ━━━"
COLLAR_INIT_BIN="$(cd "$(dirname "$0")" && pwd)"
if bash "$COLLAR_INIT_BIN/collar-watchdog" "$TARGET"; then
  echo "✅ watchdog 설치 완료"
else
  echo "⚠️  watchdog 설치 실패 — 수동 실행: collar-watchdog $TARGET"
fi

# ── collar-update: CLAUDE.md TODO 자동 채움 ──────────────────────
echo ""
echo "━━━ CLAUDE.md 자동 업데이트 ━━━"
if bash "$COLLAR_INIT_BIN/collar-update" "$TARGET"; then
  echo "✅ CLAUDE.md 업데이트 완료"
else
  echo "⚠️  collar-update 실패 — 수동 실행: collar-update $TARGET"
fi

# ── collar-github 연동 (선택) ─────────────────────────────────────
echo ""
echo "━━━ GitHub 연동 ━━━"
if [ -t 0 ]; then
  read -p "GitHub 이슈 자동화 연동할까요? [y/N]: " GH_CONFIRM
  if [ "$GH_CONFIRM" = "y" ] || [ "$GH_CONFIRM" = "Y" ]; then
    if bash "$COLLAR_INIT_BIN/collar-github" setup "$TARGET"; then
      echo "✅ GitHub 연동 완료"
    else
      echo "⚠️  collar-github 실패 — 수동 실행: collar-github setup $TARGET"
    fi
  else
    echo "건너뜀 (나중에: collar-github setup)"
  fi
else
  echo "(비대화형 실행: 건너뜀. 수동: collar-github setup $TARGET)"
fi

# ── collar-global: 글로벌 규칙/메모리 병합 (선택) ────────────────
echo ""
echo "━━━ 글로벌 규칙 병합 ━━━"
if [ -t 0 ]; then
  read -p "글로벌 AI 규칙을 ~/.claude/CLAUDE.md와 프로젝트 메모리에 병합할까요? [y/N]: " GLOBAL_CONFIRM
  if [ "$GLOBAL_CONFIRM" = "y" ] || [ "$GLOBAL_CONFIRM" = "Y" ]; then
    if bash "$COLLAR_INIT_BIN/collar-global"; then
      echo "✅ 글로벌 규칙 병합 완료"
    else
      echo "⚠️  collar-global 실패 — 수동 실행: collar-global"
    fi
  else
    echo "건너뜀 (나중에: collar-global)"
  fi
else
  echo "(비대화형 실행: 건너뜀. 수동: collar-global)"
fi

# ── 완료 ─────────────────────────────────────────────────────────
echo ""
echo "🎉 하네스 설치 완료!"
echo ""
echo "확인:"
echo "  collar-watchdog --status   # watchdog 상태"
echo "  collar-update --dry-run    # CLAUDE.md 변경 미리보기"
echo "  collar-github setup        # GitHub 연동 (미설정 시)"
echo "  collar-global              # 글로벌 규칙/메모리 재병합"
echo ""
echo "💡 CLAUDE.md를 대화형으로 완성하려면:"
echo "  collar-interview            # 7단계 인터뷰 → CLAUDE.md 자동 생성"
echo "  collar-interview --quick    # 빠른 버전 (3분)"
