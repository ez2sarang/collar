#!/usr/bin/env bash
# collar-compact — 현재 세션 컨텍스트를 LLM으로 압축해 session-compact.md에 저장
# 세션 종료 전 실행 → 다음 세션 시작 시 이 파일을 먼저 읽어 토큰 절약
# 사용법: collar-compact [프로젝트-폴더]
#          collar-compact --dry-run

set -euo pipefail

TARGET="${1:-.}"
DRY_RUN=false
[ "${1:-}" = "--dry-run" ] && DRY_RUN=true && TARGET="."
TARGET="$(cd "$TARGET" && pwd)"
PROJECT_NAME="$(basename "$TARGET")"
COLLAR_DIR="$TARGET/.collar"
MEMORY_FILE="$COLLAR_DIR/memory.md"
COMPACT_FILE="$COLLAR_DIR/session-compact.md"
TODAY="$(date +%Y-%m-%d)"

echo "🗜️  collar-compact: $PROJECT_NAME"
echo ""

if [ ! -d "$COLLAR_DIR" ]; then
  echo "❌ .collar 디렉토리가 없습니다. collar-init을 먼저 실행하세요."
  exit 1
fi

# ── 압축할 컨텍스트 수집 ──────────────────────────────────────────
CONTEXT_FILE="$(mktemp /tmp/collar-compact-XXXXX.md)"
trap "rm -f $CONTEXT_FILE" EXIT

{
  echo "# 압축 대상 컨텍스트: $PROJECT_NAME"
  echo "날짜: $TODAY"
  echo ""

  # memory.md
  if [ -f "$MEMORY_FILE" ]; then
    echo "## .collar/memory.md (전체)"
    cat "$MEMORY_FILE"
    echo ""
  fi

  # 기존 compact가 있으면 이전 요약도 포함
  if [ -f "$COMPACT_FILE" ]; then
    # Hashline 검증
    STORED_HASH=$(grep -o 'COLLAR_HASH: [a-f0-9]*' "$COMPACT_FILE" 2>/dev/null | awk '{print $2}') || true
    if [ -n "$STORED_HASH" ]; then
      CONTENT_WITHOUT_HASH=$(grep -v "COLLAR_HASH:" "$COMPACT_FILE" || true)
      ACTUAL_HASH=$(printf '%s' "$CONTENT_WITHOUT_HASH" | sha256sum 2>/dev/null | cut -c1-8 || printf '%s' "$CONTENT_WITHOUT_HASH" | md5sum | cut -c1-8)
      if [ "$STORED_HASH" != "$ACTUAL_HASH" ]; then
        echo "⚠️  [Hashline] session-compact.md 해시 불일치 — 외부 수정 감지"
        echo "   저장 해시: $STORED_HASH / 실제: $ACTUAL_HASH"
        echo "   이전 compact는 신뢰하기 어렵습니다. 새로 생성합니다."
        echo ""
      fi
    fi
    echo "## 이전 session-compact.md"
    cat "$COMPACT_FILE"
    echo ""
  fi

  # CLAUDE.md의 주요 섹션
  if [ -f "$TARGET/CLAUDE.md" ]; then
    echo "## CLAUDE.md (참고용 구조)"
    head -60 "$TARGET/CLAUDE.md"
    echo ""
  fi

} > "$CONTEXT_FILE"

# ── 압축 프롬프트 ─────────────────────────────────────────────────
PROMPT="다음은 프로젝트 '$PROJECT_NAME'의 작업 메모리와 컨텍스트입니다.

중요: 도구 사용 금지. 파일 쓰기 금지. 텍스트만 출력.

목표: 다음 AI 세션이 이 파일 하나만 읽어도 빠르게 작업을 재개할 수 있도록 압축 요약을 생성하라.

출력 형식 (이 구조만 출력, 마크다운 코드블록 없이, 앞에 다른 텍스트 없이):
---
# Session Compact — $PROJECT_NAME
날짜: $TODAY

## 프로젝트 핵심
(1-2줄: 이 프로젝트가 무엇인지)

## 현재 상태
(지금 어디까지 됐는지, 완료/미완료 항목)

## 핵심 패턴 (3개 이내)
(반복되는 중요 발견 — 다음 세션에서 알아야 할 것)

## 미완료/다음 작업
(구체적인 다음 단계)

## 주의사항
(실수하기 쉬운 것, 금지 사항)
---

$(cat "$CONTEXT_FILE")"

# ── LLM 실행 ──────────────────────────────────────────────────────
LLM_OUTPUT=""
LLM_USED=""
CLAUDE_BIN="${CLAUDE_PATH:-/opt/homebrew/bin/claude}"

if command -v claude >/dev/null 2>&1 || [ -x "$CLAUDE_BIN" ]; then
  echo "🤖 압축 중 (Claude)..."
  LLM_OUTPUT="$(timeout 120 "$CLAUDE_BIN" -p --model claude-haiku-4-5-20251001 "$PROMPT" 2>/dev/null)" && LLM_USED="claude-haiku" || true
fi

if [ -z "$LLM_OUTPUT" ] && command -v gemini >/dev/null 2>&1; then
  echo "🤖 압축 중 (Gemini fallback)..."
  LLM_OUTPUT="$(echo "$PROMPT" | gemini -p --approval-mode yolo 2>/dev/null)" && LLM_USED="gemini" || true
fi

if [ -z "$LLM_OUTPUT" ]; then
  echo "❌ LLM 압축 실패. claude 또는 gemini CLI가 필요합니다."
  echo "   수동으로 .collar/session-compact.md를 작성하세요."
  exit 1
fi

echo "   [$LLM_USED 압축 완료]"
echo ""

# ── 결과 적용 ──────────────────────────────────────────────────────
if [ "$DRY_RUN" = "true" ]; then
  echo "── 미리보기 (--dry-run) ──────────────────────────────────────"
  echo "$LLM_OUTPUT"
  echo "──────────────────────────────────────────────────────────────"
  echo ""
  echo "실제 저장: collar-compact (--dry-run 없이)"
  exit 0
fi

# 이전 compact 백업
if [ -f "$COMPACT_FILE" ]; then
  cp "$COMPACT_FILE" "$COMPACT_FILE.backup.$(date +%Y%m%d-%H%M%S)"
fi

# Hashline: 파일 무결성 해시 추가 (OMO Hashline 패턴)
FILE_HASH=$(printf '%s' "$LLM_OUTPUT" | sha256sum 2>/dev/null | cut -c1-8 || printf '%s' "$LLM_OUTPUT" | md5sum | cut -c1-8)
printf '<!-- COLLAR_HASH: %s DATE: %s -->\n%s\n' "$FILE_HASH" "$TODAY" "$LLM_OUTPUT" > "$COMPACT_FILE"
echo "✅ 압축 저장: $COMPACT_FILE"

# 크기 비교
if [ -f "$MEMORY_FILE" ]; then
  MEMORY_SIZE=$(wc -c < "$MEMORY_FILE" | tr -d ' ')
  COMPACT_SIZE=$(wc -c < "$COMPACT_FILE" | tr -d ' ')
  RATIO=$(python3 -c "print(f'{(1 - $COMPACT_SIZE/$MEMORY_SIZE)*100:.0f}%')" 2>/dev/null || echo "?")
  echo "   메모리 크기: ${MEMORY_SIZE}B → 압축: ${COMPACT_SIZE}B (${RATIO} 절약)"
fi

# memory.md에 compact 기록 (날짜 무관하게 항목 하나만 유지 — 기존 있으면 update, 없으면 append)
if [ -f "$MEMORY_FILE" ]; then
  python3 - "$MEMORY_FILE" "$TODAY" "$LLM_USED" << 'PYEOF'
import sys, pathlib, re

memory_path, today, llm_used = sys.argv[1], sys.argv[2], sys.argv[3]
content = pathlib.Path(memory_path).read_text()

new_entry_body = (
    f"**발견:** {llm_used}로 세션 컨텍스트 압축 → session-compact.md\n"
    f"**적용:** 다음 세션 시작 시 session-compact.md를 memory.md보다 먼저 읽을 것"
)

# 기존 collar-compact 실행 항목이 있으면 날짜+내용 업데이트 (날짜 무관)
existing = re.search(
    r'(### \[\d{4}-\d{2}-\d{2}\] collar-compact 실행\n)(.+?)(\n(?=###|\Z))',
    content, re.DOTALL
)
if existing:
    new_section = f"### [{today}] collar-compact 실행\n{new_entry_body}\n"
    new_content = content[:existing.start()] + new_section + content[existing.end():]
else:
    new_entry = f"\n### [{today}] collar-compact 실행\n{new_entry_body}\n"
    insert_after = "## 작업 이력 요약"
    if insert_after in content:
        pos = content.index(insert_after) + len(insert_after)
        new_content = content[:pos] + "\n" + new_entry + content[pos:]
    else:
        new_content = content + "\n" + new_entry

new_content = re.sub(r'마지막 업데이트: \d{4}-\d{2}-\d{2}', f'마지막 업데이트: {today}', new_content)
pathlib.Path(memory_path).write_text(new_content)
PYEOF
fi

echo ""
echo "🎉 collar-compact 완료!"
echo ""
echo "다음 세션 시작 시:"
echo "  1. .collar/session-compact.md 먼저 읽기"
echo "  2. 전체 memory.md는 필요할 때만"
echo "  → 토큰 절약 + 빠른 컨텍스트 복원"
